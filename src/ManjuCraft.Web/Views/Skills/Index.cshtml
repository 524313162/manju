@{
    ViewData["Title"] = "技能管理";
    Layout = "_Layout";
}
@{ var projectId = ViewData["CurrentProjectId"]?.ToString() ?? ""; }

<div class="page-header"><h1>技能管理</h1><button class="btn btn-primary modal-trigger" data-target="#new-skill-modal">+</button></div>
<div id="skills-list" class="sortable-list" data-controller="skills"></div>

<div class="modal-overlay" id="new-skill-modal">
    <div class="modal">
        <h2>新建技能</h2>
        <div class="form-group"><label>名称</label><input type="text" id="skill-name" /></div>
        <div class="form-actions">
            <button class="btn" onclick="this.closest('.modal-overlay').classList.remove('active')">取消</button>
            <button class="btn btn-primary" id="save-skill-btn">创建</button>
        </div>
    </div>
</div>

@section Scripts {
<script>
$(function () {
    var pid = '@projectId';
    function load() {
        $.get('/api/v1/projects/' + pid + '/skills', function (r) {
            var l = $('#skills-list'); l.empty();
            if (!r.data?.length) { l.html('<p style="color:var(--text-light)">暂无技能</p>'); return; }
            r.data.forEach(function (s) {
                l.append('<div class="sortable-item" data-id="'+s.id+'"><span class="drag-handle">⋮⋮</span><span style="flex:1">'+s.name+'</span>' +
                    '<button class="btn btn-sm btn-danger delete-btn" data-endpoint="skills" data-id="'+s.id+'">删除</button></div>');
            });
            l.sortable({ handle: '.drag-handle', placeholder: 'sortable-placeholder', update: function () {
                var ids = []; l.find('.sortable-item').each(function () { ids.push(parseInt($(this).data('id'))); });
                $.ajax({ url: '/api/v1/assets/skills/reorder', type: 'PUT', contentType: 'application/json', data: JSON.stringify({ ids }) });
            }}).disableSelection();
        });
    }
    $('#save-skill-btn').on('click', function () {
        $.post('/api/v1/projects/' + pid + '/skills', JSON.stringify({ name: $('#skill-name').val(), prompt: '', defaultWorkflowType: 'Txt2Img', order: 0 }), 'json', function (res) {
            if (res.success) { $('#new-skill-modal').removeClass('active'); load(); }
        });
    });
    load();
});
</script>
}
