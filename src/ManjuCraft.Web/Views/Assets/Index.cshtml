@{
    ViewData["Title"] = "资产管理";
    var projectId = ViewBag.ProjectId as long?;
    var props = ViewBag.Props as List<ManjuCraft.Domain.Models.Asset> ?? new();
    var scenes = ViewBag.Scenes as List<ManjuCraft.Domain.Models.Asset> ?? new();
    var bgms = ViewBag.Bgms as List<ManjuCraft.Domain.Models.Asset> ?? new();
}

<div class="container" style="max-width:1100px;">
    <div class="page-header">
        <h2>资产管理</h2>
        <button class="btn btn-primary btn-sm" onclick="showAddModal()">+ 添加资产</button>
    </div>

    <div class="res-tabs" id="assetTabs">
        <div class="res-tab active" onclick="switchType('Prop')">&#128736; 道具 (@props.Count)</div>
        <div class="res-tab" onclick="switchType('Scene')">&#127969; 场景 (@scenes.Count)</div>
        <div class="res-tab" onclick="switchType('Bgm')">&#127925; BGM (@bgms.Count)</div>
    </div>

    <div id="assetList"></div>
</div>

<div class="modal-overlay" id="assetModal">
    <div class="modal">
        <h3 id="assetModalTitle">添加资产</h3>
        <input type="hidden" id="editAssetIdx">
        <input type="hidden" id="editAssetId">
        <input type="hidden" id="editAssetType">
        <div class="form-group"><label>名称 *</label><input type="text" id="assetName" placeholder="输入资产名称"></div>
        <div class="form-group"><label>描述</label><textarea id="assetDesc" rows="4" placeholder="详细描述..."></textarea></div>
        <div class="form-actions">
            <button class="btn btn-ghost" onclick="hideModal('assetModal')">取消</button>
            <button class="btn btn-primary" onclick="saveAsset()">保存</button>
        </div>
    </div>
</div>

@section Scripts {
<script>
    var types = {
        'Prop': { name: '道具', icon: '&#128736;', items: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(props.Select(a => new { a.Id, a.Name, Description = a.Description ?? "" }))) },
        'Scene': { name: '场景', icon: '&#127969;', items: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(scenes.Select(a => new { a.Id, a.Name, Description = a.Description ?? "" }))) },
        'Bgm': { name: 'BGM', icon: '&#127925;', items: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(bgms.Select(a => new { a.Id, a.Name, Description = a.Description ?? "" }))) }
    };
    var currentType = 'Prop';
    var projectId = @Html.Raw(projectId?.ToString() ?? "null");

    (function(){ render(); })();

    function switchType(type) {
        currentType = type;
        document.querySelectorAll('.res-tab').forEach(function(t, i) {
            t.classList.toggle('active', ['Prop','Scene','Bgm'][i] === type);
        });
        render();
    }

    function render() {
        var cur = types[currentType];
        var items = cur.items;
        var html = '<div style="background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:24px;margin-bottom:20px;">'
            + '<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;">'
            + '<h3 style="font-size:16px;font-weight:700;">' + cur.icon + ' ' + cur.name + '（' + items.length + '）</h3>'
            + '<button class="btn btn-primary btn-sm" onclick="showAddModal()">+ 添加' + cur.name + '</button>'
            + '</div>';

        if (items.length === 0) {
            html += '<div class="empty-state"><div class="empty-state-icon">' + cur.icon + '</div><p>暂无' + cur.name + '，点击「添加」创建</p></div>';
        } else {
            items.forEach(function(a, i) {
                html += '<div class="res-item">'
                    + '<div class="res-icon" onclick="generateRes(' + i + ')" title="点击生成资源">' + cur.icon + '</div>'
                    + '<div class="res-info"><h4>' + a.Name + '</h4><p>' + (a.Description || '暂无描述') + '</p></div>'
                    + '<div class="res-actions">'
                    + '<button class="btn btn-info btn-sm" onclick="generateRes(' + i + ')">&#127912; 生成</button>'
                    + '<button class="btn btn-ghost btn-sm" onclick="showEditModal(' + i + ')">&#9998; 编辑</button>'
                    + '<button class="btn btn-ghost btn-sm" style="color:var(--danger);" onclick="deleteRes(' + i + ')">&#128465; 删除</button>'
                    + '</div></div>';
            });
        }
        html += '</div>';
        document.getElementById('assetList').innerHTML = html;
    }

    function showAddModal() {
        document.getElementById('editAssetIdx').value = '-1';
        document.getElementById('editAssetId').value = '';
        document.getElementById('editAssetType').value = currentType;
        document.getElementById('assetModalTitle').textContent = '添加' + types[currentType].name;
        document.getElementById('assetName').value = '';
        document.getElementById('assetDesc').value = '';
        showModal('assetModal');
    }

    function showEditModal(idx) {
        var item = types[currentType].items[idx];
        document.getElementById('editAssetIdx').value = idx;
        document.getElementById('editAssetId').value = item.Id;
        document.getElementById('editAssetType').value = currentType;
        document.getElementById('assetModalTitle').textContent = '编辑' + types[currentType].name;
        document.getElementById('assetName').value = item.Name;
        document.getElementById('assetDesc').value = item.Description || '';
        showModal('assetModal');
    }

    function saveAsset() {
        var idx = parseInt(document.getElementById('editAssetIdx').value);
        var type = document.getElementById('editAssetType').value;
        var name = document.getElementById('assetName').value.trim();
        var desc = document.getElementById('assetDesc').value.trim();
        if (!name) { alert('请输入名称'); return; }

        var items = types[type].items;
        var assetId = document.getElementById('editAssetId').value;

        if (idx >= 0) {
            fetch('@Url.Action("Edit", "Assets")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: new URLSearchParams({ id: assetId, name: name, description: desc })
            })
            .then(r => r.json())
            .then(res => {
                if (res.success) {
                    items[idx].Name = name;
                    items[idx].Description = desc;
                    hideModal('assetModal');
                    showToast('已保存', 'success');
                    render();
                }
            });
        } else {
            fetch('@Url.Action("Create", "Assets")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: new URLSearchParams({ projectId: projectId || 0, assetType: type, name: name, description: desc })
            })
            .then(r => r.json())
            .then(res => {
                if (res.success) {
                    items.push({ Id: res.data.id, Name: name, Description: desc });
                    hideModal('assetModal');
                    showToast('已保存', 'success');
                    render();
                }
            });
        }
    }

    function deleteRes(idx) {
        var items = types[currentType].items;
        if (!confirm('确认删除「' + items[idx].Name + '」？')) return;
        fetch('@Url.Action("Delete", "Assets")', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: new URLSearchParams({ id: items[idx].Id })
        })
        .then(r => r.json())
        .then(res => {
            if (res.success) {
                items.splice(idx, 1);
                render();
            }
        });
    }

    function generateRes(idx) {
        var a = types[currentType].items[idx];
        showToast('正在调用 ComfyUI 生成「' + a.Name + '」资源...', 'info');
        setTimeout(function() {
            showToast('资源生成完成！', 'success');
        }, 2000);
    }
</script>
}