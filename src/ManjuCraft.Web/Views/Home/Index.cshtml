@{
    ViewData["Title"] = "首页";
}

<div class="container">
    <section class="hero">
        <h2>一站式漫剧创作平台</h2>
        <p class="hero-desc">管理项目、创作剧本、提取资产、编排分镜分帧，全流程 AI 辅助制作漫剧。</p>
        <div class="hero-actions">
            <a href="@Url.Action("Index", "Projects")" class="btn btn-primary">进入项目管理 &raquo;</a>
        </div>
    </section>

    <section class="feature-grid" style="margin-top:0;">
        <div class="feature-card">
            <div class="feature-icon" style="background:#eef2ff;">&#128214;</div>
            <h3>剧本创作</h3>
            <p>AI 一键生成或手动逐章编写，支持增删改查</p>
        </div>
        <div class="feature-card">
            <div class="feature-icon" style="background:#d1fae5;">&#127909;</div>
            <h3>漫剧创作</h3>
            <p>一键提取资产，分集分镜编排，帧级别精细控制</p>
        </div>
        <div class="feature-card">
            <div class="feature-icon" style="background:#fef3c7;">&#127916;</div>
            <h3>资产管理</h3>
            <p>角色、道具、场景、BGM 统一管理，支持生图调用</p>
        </div>
    </section>
</div>