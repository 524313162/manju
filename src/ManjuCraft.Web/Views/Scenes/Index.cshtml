@{
    ViewData["Title"] = "场景管理";
    Layout = "_Layout";
}
@{ var projectId = ViewData["CurrentProjectId"]?.ToString() ?? ""; }

<div class="page-header">
    <h1>场景管理</h1>
    <button class="btn btn-primary modal-trigger" data-target="#new-scene-modal">+</button>
</div>

<div id="scenes-list" class="sortable-list" data-controller="scenes"></div>

<div class="modal-overlay" id="new-scene-modal">
    <div class="modal">
        <h2>新建场景</h2>
        <div class="form-group"><label>场景名称</label><input type="text" id="scene-name" /></div>
        <div class="form-actions">
            <button class="btn" onclick="this.closest('.modal-overlay').classList.remove('active')">取消</button>
            <button class="btn btn-primary" id="save-scene-btn">创建</button>
        </div>
    </div>
</div>

@section Scripts {
<script>
$(function () {
    var pid = '@projectId';
    function load() {
        $.get('/api/v1/projects/' + pid + '/scenes', function (r) {
            var l = $('#scenes-list'); l.empty();
            if (!r.data?.length) { l.html('<p style="color:var(--text-light)">暂无场景</p>'); return; }
            r.data.forEach(function (s) {
                l.append('<div class="sortable-item" data-id="'+s.id+'"><span class="drag-handle">⋮⋮</span><span style="flex:1">'+s.name+'</span>' +
                    '<button class="btn btn-sm generate-btn" data-endpoint="asset-generation/scenes/'+s.id+'/generate-images" data-id="'+s.id+'" data-workflow-type="'+(s.defaultWorkflowType||'Txt2Img')+'"/><button class="btn btn-sm btn-danger delete-btn" data-endpoint="scenes" data-id="'+s.id+'">删除</button></div>');
            });
            l.sortable({ handle: '.drag-handle', placeholder: 'sortable-placeholder', update: function () {
                var ids = []; l.find('.sortable-item').each(function () { ids.push(parseInt($(this).data('id'))); });
                $.ajax({ url: '/api/v1/assets/scenes/reorder', type: 'PUT', contentType: 'application/json', data: JSON.stringify({ ids }) });
            }}).disableSelection();
        });
    }
    $('#save-scene-btn').on('click', function () {
        $.post('/api/v1/projects/' + pid + '/scenes', JSON.stringify({ name: $('#scene-name').val(), imagePrompt: '', defaultWorkflowType: 'Txt2Img', order: 0 }), 'json', function (res) {
            if (res.success) { $('#new-scene-modal').removeClass('active'); load(); }
        });
    });
    load();
});
</script>
}
