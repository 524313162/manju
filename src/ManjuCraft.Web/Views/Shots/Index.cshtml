@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@{
    ViewData["Title"] = "分镜管理";
    Layout = "_Layout";
    var projectId = ViewData["CurrentProjectId"]?.ToString() ?? "";
    var episodeId = HttpContextAccessor.HttpContext?.Request?.Query["episodeId"].ToString() ?? "";
}

<script>
window.shotEpisodeId = '@episodeId';
window.shotProjectId = '@projectId';
</script>

<div class="page-header">
    <h2>分镜管理 <small style="font-weight:400;color:var(--text3);font-size:14px">(@projectId / @episodeId)</small></h2>
    <button class="btn btn-primary modal-trigger" data-target="#new-shot-modal">
        <span>+</span> 新建分镜
    </button>
</div>

<p style="color:var(--text3);font-size:14px;margin-bottom:16px;">拖拽调整分镜顺序</p>

<div id="shots-list" class="shot-list">
</div>

<div class="modal-overlay" id="new-shot-modal">
    <div class="modal" style="width:640px;max-height:90vh">
        <h2>新建分镜</h2>
        <div class="form-group">
            <label>描述</label>
            <textarea id="shot-description" rows="3" placeholder="分镜描述..."></textarea>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px">
            <div class="form-group">
                <label>景别</label>
                <select id="shot-size">
                    <option value="">— 选择 —</option>
                    <option value="远景">远景</option>
                    <option value="全景">全景</option>
                    <option value="中景">中景</option>
                    <option value="近景">近景</option>
                    <option value="特写">特写</option>
                </select>
            </div>
            <div class="form-group">
                <label>镜头运动</label>
                <select id="shot-camera">
                    <option value="">— 选择 —</option>
                    <option value="固定">固定</option>
                    <option value="前推">前推</option>
                    <option value="拉远">拉远</option>
                    <option value="平移">平移</option>
                    <option value="跟随">跟随</option>
                </select>
            </div>
            <div class="form-group">
                <label>时长（秒）</label>
                <input type="number" id="shot-duration" value="3.0" step="0.5" min="0.5" />
            </div>
        </div>
        <div class="form-group">
            <label>关联素材</label>
            <div id="asset-refs-checkboxes" style="display:flex;flex-wrap:wrap;gap:8px;padding:8px 0">
                <p style="color:var(--text3);font-size:13px">加载中...</p>
            </div>
        </div>
        <div class="form-actions">
            <button class="btn" onclick="this.closest('.modal-overlay').classList.remove('active')">取消</button>
            <button class="btn btn-primary" id="save-shot-btn">创建</button>
        </div>
    </div>
</div>

<style>
.shot-card { background:var(--surface); border:1px solid var(--border); border-radius:var(--radius); margin-bottom:14px; overflow:hidden; }
.shot-card:hover { box-shadow:var(--shadow-sm); }
.shot-header { display:flex; align-items:center; padding:12px 16px; background:#f8fafc; border-bottom:1px solid var(--border); gap:8px; }
.shot-body { display:grid; grid-template-columns:1fr 1fr; gap:16px; padding:16px; }
.shot-frames { display:flex; gap:12px; margin-top:8px; }
.shot-frame { flex:1; border:1px solid var(--border); border-radius:var(--radius-sm); padding:10px; text-align:center; background:#fafafa; }
.shot-frame .frame-label { font-size:11px; font-weight:600; color:var(--text3); text-transform:uppercase; margin-bottom:6px; }
.shot-frame .img-thumb { width:100%; height:80px; margin:0 auto 6px; }
.shot-meta { display:flex; gap:8px; flex-wrap:wrap; }
.asset-ref-tag { display:inline-flex; align-items:center; padding:2px 8px; border-radius:4px; font-size:11px; font-weight:500; }
.asset-ref-tag.actor { background:#e0e7ff; color:#4338ca; }
.asset-ref-tag.prop { background:#fef3c7; color:#a16207; }
.asset-ref-tag.scene { background:#dcfce7; color:#15803d; }
.asset-ref-tag.bgm { background:#f3e8ff; color:#7e22ce; }
</style>

@section Scripts {
<script>
$(function () {
    var projectId = window.shotProjectId || '';
    var episodeId = window.shotEpisodeId || '';

    function loadShots() {
        if (!episodeId) {
            $('#shots-list').html('<p style="color:var(--text3);padding:40px;text-align:center">请先在分集管理中选择一个分集</p>');
            return;
        }
        $.get('/api/v1/episodes/' + episodeId + '/shots', function (res) {
            var list = $('#shots-list');
            list.empty();
            if (!res.data || !res.data.length) {
                list.html('<p style="color:var(--text3);padding:40px;text-align:center">暂无分镜，点击"新建分镜"添加</p>');
                return;
            }
            res.data.forEach(function (shot, i) {
                var assetRefs = [];
                try { if (shot.assetRefs) assetRefs = JSON.parse(shot.assetRefs); } catch(e) {}

                var refTags = '';
                if (assetRefs.length) {
                    assetRefs.forEach(function (ref) {
                        var type = (ref.type || '').toLowerCase();
                        refTags += '<span class="asset-ref-tag ' + type + '">' + (ref.name || ref.type || '?') + '</span> ';
                    });
                }

                var metaParts = [];
                if (shot.shotSize) metaParts.push('<span class="badge badge-blue">' + shot.shotSize + '</span>');
                if (shot.cameraMovement) metaParts.push('<span class="badge badge-purple">' + shot.cameraMovement + '</span>');
                if (shot.duration) metaParts.push('<span class="badge badge-warn">' + shot.duration + 's</span>');

                var framesHtml = '';
                if (shot.frames && shot.frames.length) {
                    framesHtml = '<div class="shot-frames">';
                    var sortedFrames = shot.frames.sort(function(a,b) { return a.order - b.order; });
                    sortedFrames.forEach(function (f) {
                        framesHtml += '<div class="shot-frame"><div class="frame-label">' + f.frameType + '</div>' +
                            '<div class="img-thumb empty" style="height:60px">🖼️</div>' +
                            '<div style="font-size:11px;color:var(--text3)">' + (f.startTime || '') + (f.duration ? '/' + f.duration + 's' : '') + '</div>' +
                            '</div>';
                    });
                    framesHtml += '</div>';
                }

                var html = '<div class="shot-card" data-id="' + shot.id + '">' +
                    '<div class="shot-header">' +
                    '<span class="drag-handle" style="cursor:grab">⋮⋮</span>' +
                    '<span class="shot-num">分镜 ' + (i+1) + '</span>' +
                    '<div class="shot-meta">' + metaParts.join('') + '</div>' +
                    '<div style="margin-left:auto;display:flex;gap:6px">' +
                    '<button class="btn btn-sm generate-btn" data-endpoint="shots/' + shot.id + '/generate-firstframe" data-id="' + shot.id + '"><span class="spinner"></span>首帧</button>' +
                    '<button class="btn btn-sm generate-btn" data-endpoint="shots/' + shot.id + '/generate-video" data-id="' + shot.id + '"><span class="spinner"></span>视频</button>' +
                    '<button class="btn btn-sm btn-danger delete-btn" data-endpoint="shots" data-id="' + shot.id + '">删除</button>' +
                    '</div>' +
                    '</div>' +
                    '<div class="shot-body">' +
                    '<div><strong style="font-size:13px;color:var(--text3)">描述</strong><p style="font-size:14px;margin-top:4px;line-height:1.6">' + (shot.description || '-') + '</p>' +
                    (refTags ? '<div style="margin-top:8px"><strong style="font-size:12px;color:var(--text3)">关联素材</strong><div style="margin-top:4px;display:flex;gap:4px;flex-wrap:wrap">' + refTags + '</div></div>' : '') +
                    '</div>' +
                    '<div>' + framesHtml + '</div>' +
                    '</div>' +
                    '</div>';

                list.append(html);
            });

            list.sortable({
                handle: '.drag-handle',
                placeholder: 'sortable-placeholder',
                update: function () {
                    var ids = [];
                    list.find('.shot-card').each(function () { ids.push(parseInt($(this).data('id'))); });
                    if (ids.length === 0) return;
                    $.ajax({
                        url: '/api/v1/shots/reorder',
                        type: 'PUT',
                        contentType: 'application/json',
                        data: JSON.stringify({ shotIds: ids })
                    });
                }
            }).disableSelection();
        });
    }

    function loadAssetCheckboxes() {
        var $container = $('#asset-refs-checkboxes');
        $container.html('<p style="color:var(--text3);font-size:13px">加载中...</p>');

        var assetTypes = ['Actor', 'Prop', 'Scene'];
        var typeLabels = { Actor: '演员', Prop: '道具', Scene: '场景' };
        var promises = [];

        assetTypes.forEach(function (type) {
            var endpoint = type === 'Actor' ? 'actors' : type.toLowerCase() + 's';
            promises.push(
                $.get('/api/v1/projects/' + projectId + '/' + endpoint).then(function (res) {
                    return { type: type, items: res.data || [] };
                })
            );
        });

        $.when.apply($, promises).done(function () {
            var args = arguments;
            $container.empty();

            if (promises.length === 1) args = [args];

            for (var i = 0; i < assetTypes.length; i++) {
                var result = args[i];
                var type = assetTypes[i];
                var items = result.items || [];

                if (!items.length) continue;

                var group = $('<div style="margin-bottom:4px"><strong style="font-size:12px;color:var(--text3)">' + typeLabels[type] + '</strong></div>');
                items.forEach(function (item) {
                    var label = $('<label style="display:inline-flex;align-items:center;gap:4px;margin:4px 8px 4px 0;font-size:13px;cursor:pointer">' +
                        '<input type="checkbox" class="asset-ref-cb" data-type="' + type + '" data-id="' + item.id + '" data-name="' + item.name + '" /> ' +
                        item.name + '</label>');
                    group.append(label);
                });
                $container.append(group);
            }

            if ($container.children().length === 0) {
                $container.html('<p style="color:var(--text3);font-size:13px">暂无可用素材，请先在素材管理中添加</p>');
            }
        });
    }

    $('#save-shot-btn').on('click', function () {
        var assetRefs = [];
        $('.asset-ref-cb:checked').each(function () {
            assetRefs.push({ type: $(this).data('type'), id: $(this).data('id'), name: $(this).data('name') });
        });

        var data = {
            description: $('#shot-description').val().trim(),
            shotSize: $('#shot-size').val(),
            cameraMovement: $('#shot-camera').val(),
            duration: parseFloat($('#shot-duration').val()) || 3.0,
            assetRefs: JSON.stringify(assetRefs),
            order: 0
        };

        $.ajax({
            url: '/api/v1/episodes/' + episodeId + '/shots',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(data),
            success: function (res) {
                if (res.success) {
                    $('#new-shot-modal').removeClass('active');
                    $('#shot-description').val('');
                    $('#shot-size, #shot-camera').val('');
                    $('#shot-duration').val('3.0');
                    $('.asset-ref-cb').prop('checked', false);
                    loadShots();
                }
            }
        });
    });

    $('.modal-trigger').on('click', function () {
        if ($(this).data('target') === '#new-shot-modal') {
            loadAssetCheckboxes();
        }
    });

    loadShots();
});
</script>
}