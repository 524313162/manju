@{
    ViewData["Title"] = "演员管理";
    Layout = "_Layout";
}
@{ var projectId = ViewData["CurrentProjectId"]?.ToString() ?? ""; }

<div class="page-header" style="display:flex !important; align-items:center !important; justify-content:space-between !important; margin-bottom:24px">
    <div>
        <h2>🎭 演员管理</h2>
        <p style="font-size:14px;color:var(--text3);margin-top:4px">管理角色设定与生成素材</p>
    </div>
    <div style="display:flex;gap:8px">
        <button class="btn btn-primary btn-sm modal-trigger" data-target="#createActorModal">+ 添加</button>
        <button class="btn btn-ghost btn-sm" id="generate-all-btn">✨ 批量生成提示词</button>
    </div>
</div>

<div class="table-wrap" id="actors-table-wrap" style="max-width:900px">
    <p style="padding:40px;text-align:center;color:var(--text3)">加载中...</p>
</div>

<div class="modal-overlay" id="createActorModal">
    <div class="modal">
        <h3>添加演员</h3>
        <div class="form-group">
            <label>演员名称</label>
            <input type="text" id="actorName" placeholder="如：勇者" />
        </div>
        <div class="form-group">
            <label>详细描述</label>
            <textarea id="actorDesc" rows="3" placeholder="如：身穿银甲的年轻勇者，棕色短发，蓝色眼睛"></textarea>
        </div>
        <div class="form-actions">
            <button class="btn btn-ghost modal-close">取消</button>
            <button class="btn btn-primary btn-sm" id="saveActorBtn">保存</button>
        </div>
    </div>
</div>

@section Scripts {
<script>
$(function () {
    var projectId = '@projectId';
    if (!projectId) { alert('缺少项目ID'); return; }

    function loadActors() {
        $.get('/api/v1/projects/' + projectId + '/actors', function (res) {
            var wrap = $('#actors-table-wrap');
            if (!res.data || !res.data.length) {
                wrap.html('<div style="padding:40px;text-align:center;color:var(--text3);font-size:14px">' +
                    '<div style="font-size:36px;margin-bottom:12px">🎭</div>暂无演员，点击"+ 添加"创建第一个角色</div>');
                return;
            }
            var html = '<table><thead><tr>' +
                '<th style="width:40px">#</th>' +
                '<th style="width:60px">预览</th>' +
                '<th>名称</th>' +
                '<th>描述</th>' +
                '<th style="width:90px">工作流</th>' +
                '<th style="width:80px">状态</th>' +
                '<th style="width:200px">操作</th>' +
                '</tr></thead><tbody>';
            res.data.forEach(function (a, i) {
                var statusHtml = '<span class="badge badge-blue"><span class="badge-dot"></span> 待生成</span>';
                var previewHtml = '<div class="img-thumb empty"><span>+</span></div>';
                html += '<tr data-id="' + a.id + '">' +
                    '<td>' + (i + 1) + '</td>' +
                    '<td>' + previewHtml + '</td>' +
                    '<td><strong>' + a.name + '</strong></td>' +
                    '<td style="color:var(--text3);max-width:220px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">' + (a.description || '-') + '</td>' +
                    '<td><span class="badge badge-purple">' + (a.defaultWorkflowType || 'Txt2Img') + '</span></td>' +
                    '<td>' + statusHtml + '</td>' +
                    '<td><div class="actions-bar">' +
                    '<button class="action" onclick="genPrompt(' + a.id + ')">📝 提示词</button>' +
                    '<button class="action action-ok" onclick="genImage(' + a.id + ')">🎨 生成</button>' +
                    '<button class="action action-d" onclick="delActor(' + a.id + ')">🗑️</button>' +
                    '</div></td></tr>';
            });
            html += '</tbody></table>';
            wrap.html(html);
        });
    }

    window.genPrompt = function (id) {
        $.ajax({
            url: '/api/v1/actors/' + id + '/generate-prompt',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify({ description: '' }),
            success: function (res) { alert(res.success ? '提示词生成成功' : '失败: ' + res.message); }
        });
    };
    window.genImage = function (id) {
        $.ajax({
            url: '/api/v1/AssetGeneration/actors/' + id + '/generate',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify({ workflowType: 'Txt2Img' }),
            success: function (res) { alert(res.success ? '图片生成任务已提交' : '失败: ' + res.message); }
        });
    };
    window.delActor = function (id) {
        if (!confirm('确定要删除这个演员吗？')) return;
        $.ajax({
            url: '/api/v1/actors/' + id,
            type: 'DELETE',
            success: function (res) { loadActors(); }
        });
    };

    $('#saveActorBtn').on('click', function () {
        var name = $('#actorName').val().trim();
        if (!name) { alert('请输入演员名称'); return; }
        $.ajax({
            url: '/api/v1/projects/' + projectId + '/actors',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify({
                name: name,
                description: $('#actorDesc').val().trim(),
                fourViewPrompt: '',
                defaultWorkflowType: 'Txt2Img',
                order: 0
            }),
            success: function (res) {
                if (res.success) {
                    $('#createActorModal').removeClass('show active');
                    $('#actorName, #actorDesc').val('');
                    loadActors();
                }
            }
        });
    });

    $('#generate-all-btn').on('click', function () {
        alert('批量生成所有演员的提示词...');
    });

    loadActors();
});
</script>
}
