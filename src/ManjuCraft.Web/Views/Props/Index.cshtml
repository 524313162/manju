@{
    ViewData["Title"] = "道具管理";
    Layout = "_Layout";
}
@{ var projectId = ViewData["CurrentProjectId"]?.ToString() ?? ""; }

<div class="page-header">
    <h1>道具管理</h1>
    <button class="btn btn-primary modal-trigger" data-target="#new-prop-modal">
        <span>+</span> 新建道具
    </button>
</div>

<div id="props-list" class="sortable-list" data-controller="props">
</div>

<div class="modal-overlay" id="new-prop-modal">
    <div class="modal">
        <h2>新建道具</h2>
        <div class="form-group">
            <label>道具名称</label>
            <input type="text" id="prop-name" placeholder="魔法杖" />
        </div>
        <div class="form-actions">
            <button class="btn" onclick="this.closest('.modal-overlay').classList.remove('active')">取消</button>
            <button class="btn btn-primary" id="save-prop-btn">创建</button>
        </div>
    </div>
</div>

@section Scripts {
<script>
$(function () {
    var projectId = '@projectId';
    function load() {
        $.get('/api/v1/projects/' + projectId + '/props', function (res) {
            var list = $('#props-list');
            list.empty();
            if (!res.data?.length) { list.html('<p style="color:var(--text-light)">暂无道具</p>'); return; }
            res.data.forEach(function (p) {
                list.append('<div class="sortable-item" data-id="' + p.id + '">' +
                    '<span class="drag-handle">⋮⋮</span><span style="flex:1">' + p.name + '</span>' +
                    '<button class="btn btn-sm generate-btn" data-endpoint="asset-generation/props/' + p.id + '/generate-images" data-id="' + p.id + '" data-workflow-type="' + (p.defaultWorkflowType||'Txt2Img') + '"><span class="spinner"></span>生成</button>' +
                    '<button class="btn btn-sm btn-danger delete-btn" data-endpoint="props" data-id="' + p.id + '">删除</button></div>');
            });
            list.sortable({ handle: '.drag-handle', placeholder: 'sortable-placeholder', update: function () {
                var ids = []; list.find('.sortable-item').each(function () { ids.push(parseInt($(this).data('id'))); });
                $.ajax({ url: '/api/v1/assets/props/reorder', type: 'PUT', contentType: 'application/json', data: JSON.stringify({ ids }) });
            }}).disableSelection();
        });
    }
    $('#save-prop-btn').on('click', function () {
        $.post('/api/v1/projects/' + projectId + '/props', JSON.stringify({ name: $('#prop-name').val(), twoViewPrompt: '', defaultWorkflowType: 'Txt2Img', order: 0 }), 'json', function (r) {
            if (r.success) { $('#new-prop-modal').removeClass('active'); load(); }
        });
    });
    load();
});
</script>
}
