@{
    ViewData["Title"] = "分集管理";
    Layout = "_Layout";
}
<div class="page-header">
    <h2>分集管理</h2>
    <button class="btn btn-primary modal-trigger" data-target="#new-episode-modal">
        <span>+</span> 新建分集
    </button>
</div>

<p style="color:var(--text3);font-size:14px;margin-bottom:16px;">拖拽调整分集顺序 | 每集可关联一个故事章节</p>

<div id="episodes-list" class="sortable-list" data-controller="episodes">
</div>

<div class="modal-overlay" id="new-episode-modal">
    <div class="modal">
        <h2>新建分集</h2>
        <div class="form-group">
            <label>分集名称</label>
            <input type="text" id="episode-name" placeholder="第一集" />
        </div>
        <div class="form-group">
            <label>关联章节（可选）</label>
            <select id="episode-chapter">
                <option value="">— 不关联 —</option>
            </select>
        </div>
        <div class="form-group">
            <label>时长（秒）</label>
            <input type="number" id="episode-duration" value="300" />
        </div>
        <div class="form-actions">
            <button class="btn" onclick="this.closest('.modal-overlay').classList.remove('active')">取消</button>
            <button class="btn btn-primary" id="save-episode-btn">创建</button>
        </div>
    </div>
</div>

@section Scripts {
<script>
$(function () {
    var projectId = '@ViewData["CurrentProjectId"]';

    function loadChapters(selectedId) {
        $.get('/api/v1/projects/' + projectId + '/story', function (res) {
            var $sel = $('#episode-chapter');
            $sel.find('option:not(:first)').remove();
            if (res.data && res.data.chapters) {
                res.data.chapters.sort(function (a, b) { return a.order - b.order; });
                res.data.chapters.forEach(function (ch) {
                    $sel.append('<option value="' + ch.id + '" ' + (selectedId && ch.id === selectedId ? 'selected' : '') + '>' +
                        (ch.chapterNumber || '') + ' ' + (ch.chapterName || '') + '</option>');
                });
            }
        });
    }

    function loadEpisodes() {
        $.get('/api/v1/episodes/project/' + projectId, function (res) {
            var list = $('#episodes-list');
            list.empty();
            if (!res.data || !res.data.length) {
                list.html('<p style="color:var(--text3);">暂无分集，点击"新建分集"添加</p>');
                return;
            }
            res.data.forEach(function (ep, i) {
                var chapterLabel = ep.storyChapterId ? '<span class="badge badge-info">章节 #' + ep.storyChapterId + '</span>' : '';
                list.append('<div class="sortable-item" data-id="' + ep.id + '">' +
                    '<span class="drag-handle">⋮⋮</span>' +
                    '<span style="flex:1">' + ep.name + '</span>' +
                    chapterLabel +
                    '<span style="color:var(--text3);font-size:12px;">' + ep.duration + 's</span>' +
                    '<span style="color:var(--text3);font-size:12px;">' + ep.shotCount + ' 分镜</span>' +
                    '<a href="/Shots/Index?projectId=' + projectId + '&episodeId=' + ep.id + '" class="btn btn-sm">进入</a>' +
                    '<button class="btn btn-sm btn-danger delete-btn" data-endpoint="episodes" data-id="' + ep.id + '">删除</button>' +
                    '</div>');
            });
            initSortable(list);
        });
    }

    function initSortable($list) {
        $list.sortable({
            handle: '.drag-handle',
            placeholder: 'sortable-placeholder',
            update: function () {
                var ids = [];
                $list.find('.sortable-item').each(function () { ids.push(parseInt($(this).data('id'))); });
                if (ids.length === 0) return;
                $.ajax({
                    url: '/api/v1/episodes/reorder',
                    type: 'PUT',
                    contentType: 'application/json',
                    data: JSON.stringify({ episodeIds: ids })
                });
            }
        }).disableSelection();
    }

    $('#save-episode-btn').on('click', function () {
        var name = $('#episode-name').val().trim();
        if (!name) { alert('请输入分集名称'); return; }
        var chapterId = $('#episode-chapter').val();

        var data = {
            name: name,
            duration: parseInt($('#episode-duration').val()) || 300,
            order: 0
        };
        if (chapterId) data.storyChapterId = parseInt(chapterId);

        $.ajax({
            url: '/api/v1/episodes/project/' + projectId,
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(data),
            success: function (res) {
                if (res.success) {
                    $('#new-episode-modal').removeClass('active');
                    loadEpisodes();
                }
            }
        });
    });

    $('.modal-trigger').on('click', function () {
        loadChapters(null);
    });

    loadEpisodes();
});
</script>
}