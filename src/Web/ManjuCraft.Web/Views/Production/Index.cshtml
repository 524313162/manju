@{
    ViewData["Title"] = "漫剧创作";
    var project = ViewBag.Project as ManjuCraft.Domain.Models.Project;
}

@if (project == null)
{
    <div class="container">
        <div class="empty-state">
            <div class="empty-state-icon">&#128196;</div>
            <p>请先选择一个项目</p>
            <a href="@Url.Action("Index", "Projects")" class="btn btn-primary" style="margin-top:16px;">返回项目管理</a>
        </div>
    </div>
    return;
}

<div class="prod-layout">
    <div class="episode-sidebar">
        <div class="episode-sidebar-header">
            <a href="@Url.Action("Index", "Projects")" class="back-link">&laquo; 返回项目</a>
            <h3 id="pName">@project.Name</h3>
            <p id="pStatus">加载中...</p>
        </div>
        <div class="episode-list" id="epList"></div>
        <div class="episode-sidebar-footer">
            <button class="btn btn-primary btn-sm" style="width:100%;" onclick="extractAllAssets()">&#129302; 一键提取资产</button>
            <a href="@Url.Action("Index", "Story", new { projectId = project.Id })" class="btn btn-ghost btn-sm" style="width:100%;margin-top:6px;color:#a78bfa;display:block;text-align:center;">&#128214; 编辑剧本</a>
        </div>
    </div>

    <div class="prod-main">
        <div class="prod-toolbar">
            <h2 id="mainTitle">漫剧创作</h2>
            <div class="prod-tabs">
                <div class="prod-tab active" data-tab="shots" onclick="switchTab('shots')">分镜</div>
                <div class="prod-tab" data-tab="content" onclick="switchTab('content')">章节内容</div>
            </div>
        </div>
        <div class="prod-content" style="padding:16px 24px;">
            <div id="tab-shots" class="tab-panel">
                <div id="storyboardArea"></div>
            </div>
            <div id="tab-content" class="tab-panel hidden">
                <div id="contentArea"></div>
            </div>
        </div>
    </div>
</div>

<div class="modal-overlay" id="frameListModal">
    <div class="modal" style="width:700px;">
        <h3 id="frameListTitle">分帧模板</h3>
        <div id="frameListBody" style="max-height:55vh;overflow-y:auto;"></div>
        <div class="form-actions"><button class="btn btn-ghost" onclick="hideModal('frameListModal')">关闭</button></div>
    </div>
</div>

<div class="modal-overlay" id="extractConfirmModal">
    <div class="modal" style="width:640px;">
        <h3>&#129302; 资产提取确认</h3>
        <p style="font-size:13px;color:var(--text2);margin-bottom:14px;">AI 从剧本内容中提取到以下资产，请勾选需要入库的：</p>
        <div id="extractConfirmBody" style="max-height:45vh;overflow-y:auto;"></div>
        <div class="form-actions">
            <button class="btn btn-ghost" onclick="hideModal('extractConfirmModal')">取消</button>
            <button class="btn btn-primary" onclick="confirmExtractAssets()">确认入库</button>
        </div>
    </div>
</div>

@section Scripts {
<script>
    var projectId = @project.Id;
    var chapters = [], currentChapterIdx = -1;
    var currentTab = 'shots';
    var shotState = {};
    var _frameTemplates = [
        { first: '晨曦微露，薄雾笼罩的村落全景', middle: '镜头缓缓扫过村庄，石板路上有早起的居民开始劳作', last: '视线逐渐拉远，远景渐入云海' },
        { first: '主角从村口大步走来，身披斗篷腰佩长剑', middle: '中景跟拍主角穿过市集，周围村民纷纷侧目低语', last: '主角在镜头前停步，缓缓转身' },
        { first: '面部大特写——主角瞳孔微颤，额头渗出细密汗珠', middle: '镜头缓慢前推至眼部特写', last: '特写维持在眉眼之间，一滴泪珠从眼角滑落' },
        { first: '过肩镜头——主角肩部占据画面右下角', middle: '正反打切换至精灵少女近景', last: '镜头回到过肩视角，精灵少女收起长弓' },
        { first: '一枚古朴的金色宝石悬浮于祭坛之上', middle: '镜头围绕宝石缓缓旋转，符文光纹逐渐变亮', last: '一只手从画面右侧缓缓伸入' },
        { first: '全景俯拍——角色在古老的森林中穿行', middle: '镜头平移跟拍角色在森林中的奔跑', last: '角色冲出树林到达悬崖边缘，豁然开朗' },
        { first: '超大远景——古战场遗迹横亘在荒原之上', middle: '镜头缓缓拉远，荒原上星罗棋布的篝火逐渐化为光点', last: '画面升向高空穿破云层' }
    ];

    (function(){ init(); })();

    function init() {
        document.getElementById('pName').textContent = '@project.Name';
        loadChapters();
    }

    function loadChapters() {
        fetch('/Story/LoadChaptersForProduction?projectId=' + projectId)
            .then(function(r){ return r.json(); })
            .then(function(res){
                if (res && res.success && res.data) {
                    chapters = res.data;
                } else {
                    chapters = [];
                }
                render();
            })
            .catch(function(){ chapters = []; render(); });
    }

    function render() {
        renderSidebar();
        if (currentTab === 'shots') renderShotsTab();
        else renderContentTab();
    }

    function renderSidebar() {
        document.getElementById('pStatus').textContent = chapters.length + ' 章节';
        var h = '';
        chapters.forEach(function(c, i) {
            var hasShots = shotState[i] && shotState[i].shots && shotState[i].shots.length > 0;
            h += '<div class="episode-item' + (i === currentChapterIdx ? ' active' : '') + '" onclick="selectChapter(' + i + ')">'
                + '<span class="episode-num">第' + (c.chapterNumber || (i+1)) + '章</span>'
                + '<div class="episode-info"><div class="episode-name">' + c.chapterName + '</div>'
                + '<div class="episode-meta">' + (hasShots ? shotState[i].shots.length + ' 分镜' : '未提取分镜') + '</div></div></div>';
        });
        document.getElementById('epList').innerHTML = h || '<div style="padding:20px;text-align:center;color:var(--text3);font-size:13px;">暂无章节，请先创建剧本<br><a class="back-link" style="color:var(--info);cursor:pointer;display:inline-block;margin-top:8px;" href="?type=Actor&projectId=' + projectId + '">编辑剧本</a></div>';
    }

    function selectChapter(idx) {
        currentChapterIdx = idx;
        render();
        document.getElementById('mainTitle').textContent = '第' + chapters[idx].chapterNumber + '章 — ' + chapters[idx].chapterName;
    }

    function switchTab(tab) {
        currentTab = tab;
        document.querySelectorAll('.prod-tab').forEach(function(t){ t.classList.remove('active'); if (t.dataset.tab === tab) t.classList.add('active'); });
        document.querySelectorAll('.tab-panel').forEach(function(p){ p.classList.add('hidden'); });
        document.getElementById('tab-' + tab).classList.remove('hidden');
        if (tab === 'shots') renderShotsTab();
        else renderContentTab();
    }

    function renderShotsTab() {
        if (chapters.length === 0 || currentChapterIdx === -1) {
            document.getElementById('storyboardArea').innerHTML = '<div class="no-content" style="text-align:center;padding:60px 20px;color:var(--text3);">'
                + '<div class="icon" style="font-size:40px;margin-bottom:12px;">&#128214;</div>'
                + '<p>请先编辑剧本添加章节</p><p style="font-size:12px;color:var(--text3);margin-top:8px;"><a href="@Url.Action("Index", "Story", new { projectId = project.Id })" style="color:var(--info);text-decoration:none;">&#128214; 去编辑剧本</a></p></div>';
            return;
        }

        var ch = chapters[currentChapterIdx];
        if (!shotState[currentChapterIdx]) shotState[currentChapterIdx] = { shots: [], loading: false };

        var state = shotState[currentChapterIdx];
        var h = '<div style="margin-bottom:16px;"><strong>' + ch.chapterName + '</strong></div>';

        if (state.loading) {
            h += '<div style="text-align:center;padding:20px;"><div class="spinner" style="display:inline-block;width:24px;height:24px;border:2px solid var(--border);border-top-color:var(--info);border-radius:50%;animation:spin .6s linear infinite;"></div>'
                + '<p style="margin-top:10px;color:var(--text2);font-size:13px;">正在调用 AI 生成分镜...</p></div>';
        } else if (state.shots && state.shots.length > 0) {
            h += '<div style="display:flex;gap:8px;margin-bottom:16px;">'
                + '<button class="btn btn-primary btn-sm" onclick="regenerateShots()">&#129302; 重新生成分镜</button>'
                + '<button class="btn btn-ghost btn-sm" onclick="showFrameTemplates()">&#129300; 分帧模板</button>'
                + '</div>';

            h += '<div style="display:flex;flex-direction:column;gap:12px;">';
            state.shots.forEach(function(shot, si) {
                var frames = shot.frames || [];
                h += '<div class="shot-item" style="background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:16px;">'
                    + '<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;">'
                    + '<strong style="font-size:14px;">分镜 ' + (si+1) + ' — ' + (shot.shotName || shot.shotNumber || '') + '</strong>'
                    + '<div style="display:flex;gap:4px;">'
                    + '<button class="btn btn-info btn-sm" onclick="generateStoryboardShot(' + si + ')">&#127912; 生成分镜图</button>'
                    + '<button class="btn btn-info btn-sm" onclick="generateShotVideo(' + si + ')">&#127909; 生成视频</button>'
                    + '</div></div>';

                var genStatus = [];
                if (shot.generatingStoryboard) genStatus.push('<span class="spinner" style="display:inline-block;width:14px;height:14px;border:2px solid var(--border);border-top-color:var(--info);border-radius:50%;animation:spin .6s linear infinite;"></span> 生成分镜图...');
                if (shot.generatingVideo) genStatus.push('生成视频中...');
                if (shot.generatingFrame) genStatus.push('生成首帧图...');
                if (genStatus.length > 0) {
                    h += '<div style="text-align:center;padding:12px;background:var(--bg);border-radius:6px;margin-bottom:10px;color:var(--text2);font-size:13px;">' + genStatus.join(' | ') + '</div>';
                }

                if (shot.storyboardUrl) {
                    h += '<div style="margin-bottom:10px;"><img src="' + shot.storyboardUrl + '" style="width:100%;max-height:280px;object-fit:cover;border-radius:8px;" onclick="showImagePreview(\'' + shot.storyboardUrl + '\')"></div>';
                }

                if (frames.length > 0) {
                    h += '<div style="display:flex;gap:8px;overflow-x:auto;padding:8px 0;">';
                    frames.forEach(function(f, fi) {
                        var frameType = f.frameType || '';
                        var icon = frameType === 'First' ? '&#128640;' : frameType === 'Last' ? '&#9940;' : '&#9654;';
                        h += '<div style="min-width:140px;padding:10px;background:var(--bg);border-radius:6px;text-align:center;">'
                            + '<div style="font-size:12px;color:var(--text3);margin-bottom:4px;">' + icon + ' ' + frameType + '</div>'
                            + '<div style="font-size:12px;margin-bottom:6px;">' + (f.description || '暂无描述') + '</div>';
                        if (f.hasImage && f.imagePath) {
                            h += '<img src="' + f.imagePath + '" style="width:100%;height:80px;object-fit:cover;border-radius:4px;margin-top:6px;" onclick="showImagePreview(\'' + f.imagePath + '\')">';
                        } else {
                            h += '<div style="width:100%;height:80px;background:var(--surface2);border:1px dashed var(--border);border-radius:4px;display:flex;align-items:center;justify-content:center;margin-top:6px;font-size:24px;color:var(--text3);">&#128365;</div>';
                        }
                        h += '</div>';
                    });
                    h += '</div>';
                }

                var hasFramesWithImage = frames.some(function(ff) { return ff.hasImage; });
                if (!hasFramesWithImage) {
                    h += '<button class="btn btn-ghost btn-sm" style="width:100%;margin-top:8px;" onclick="generateFrameImage(' + si + ', 0)">&#127912; 生成首帧图</button>';
                }

                h += '</div>';
            });
            h += '</div>';
        } else {
            h += '<div style="text-align:center;padding:40px 20px;color:var(--text3);">'
                + '<div class="icon" style="font-size:40px;margin-bottom:12px;">&#127916;</div>'
                + '<p>该章节暂无分镜数据</p><p style="font-size:12px;color:var(--text3);margin-top:8px;">'
                + '<button class="btn btn-primary btn-sm" onclick="regenerateShots()">&#129302; 提取分镜</button></p></div>';
        }

        document.getElementById('storyboardArea').innerHTML = h;
    }

    function renderContentTab() {
        if (chapters.length === 0 || currentChapterIdx === -1) {
            document.getElementById('contentArea').innerHTML = '<div class="no-content" style="text-align:center;padding:60px 20px;color:var(--text3);">'
                + '<div class="icon" style="font-size:40px;margin-bottom:12px;">&#128214;</div>'
                + '<p>暂无章节内容</p></div>';
            return;
        }

        var ch = chapters[currentChapterIdx];
        var h = '<div style="background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:24px;">'
            + '<h3 style="font-size:18px;font-weight:700;margin-bottom:4px;">' + ch.chapterNumber + ' — ' + ch.chapterName + '</h3>'
            + '<div class="content-body" style="margin-top:16px;">' + formatMarkdown(ch.content || '') + '</div></div>';
        document.getElementById('contentArea').innerHTML = h;
    }

    function regenerateShots() {
        if (currentChapterIdx === -1) return;
        shotState[currentChapterIdx] = { shots: [], loading: true };
        renderShotsTab();

        var chapter = chapters[currentChapterIdx];
        var systemPrompt = '你是一个专业的漫剧分镜师。请将章节内容拆分为多个分镜脚本。每个分镜包含：shotNumber(分镜编号), shotName(分镜名称), shotSize(景别:全景/中景/特写), cameraMovement(运镜:固定/前推/平移/环绕), duration(时长秒), frames(帧数组,含frameType:First/Middle/Last, description, hasImage:false)。\n\n输出严格的 JSON 数组，格式如：[{"shotNumber":"SH001","shotName":"场景一","shotSize":"全景","cameraMovement":"固定","duration":5,"frames":[{"frameType":"First","description":"描述1","startTime":0,"duration":2,"order":0,"hasImage":false},{"frameType":"Middle","description":"描述2","startTime":2,"duration":2.5,"order":1,"hasImage":false},{"frameType":"Last","description":"描述3","startTime":4.5,"duration":3.5,"order":2,"hasImage":false}]}]。注意：只返回 JSON 数组，不要其他内容。';
        var userMessage = '请为以下章节内容生成分镜脚本：\n\n' + chapter.content;

        fetch('/api/v1/ai/chat', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ userPrompt: userMessage, systemPrompt: systemPrompt, maxLength: 8192 })
        })
            .then(function(r){ return r.json(); })
            .then(function(res) {
                if (res && res.success) {
                    try {
                        var text = res.data;
                        var match = text.match(/```(?:json)?\s*([\s\S]*?)```/);
                        var jsonText = match ? match[1].trim() : text;
                        var parsed = JSON.parse(jsonText);
                        if (Array.isArray(parsed) && parsed.length > 0) {
                            var shots = parsed.map(function(s, i) {
                                return {
                                    shotNumber: s.shotNumber || 'SH' + String(i+1).padStart(3,'0'),
                                    shotName: s.shotName || '分镜 ' + (i+1),
                                    shotSize: s.shotSize || '',
                                    cameraMovement: s.cameraMovement || '',
                                    duration: s.duration || 5,
                                    frames: (s.frames || []).map(function(f) {
                                        return { ...f, hasImage: false };
                                    }),
                                    hasFirstFrame: false, hasVideo: false
                                };
                            });
                            shotState[currentChapterIdx] = { shots: shots };
                            render();
                            return;
                        }
                    } catch(e) {
                        console.error('解析分镜 JSON 失败:', e);
                    }
                }
                generateDemoShots(chapter);
            })
            .catch(function(){ generateDemoShots(chapter); });
    }

    function generateDemoShots(chapter) {
        var shots = [];
        var t = _frameTemplates[Math.floor(Math.random() * _frameTemplates.length)];
        for (var i = 0; i < 3; i++) {
            shots.push({
                shotNumber: 'SH' + String(i+1).padStart(3,'0'),
                shotName: '分镜 ' + (i+1),
                shotSize: ['全景','中景','特写'][i % 3],
                cameraMovement: ['固定','前推','平移'][i % 3],
                duration: 5 + Math.floor(Math.random() * 5),
                frames: [
                    { frameType: 'First', description: t.first, startTime: 0, duration: 2, order: 0, hasImage: false },
                    { frameType: 'Middle', description: t.middle, startTime: 2, duration: 2.5, order: 1, hasImage: false },
                    { frameType: 'Last', description: t.last, startTime: 4.5, duration: 3.5, order: 2, hasImage: false }
                ],
                hasFirstFrame: false, hasVideo: false
            });
        }
        shotState[currentChapterIdx] = { shots: shots };
        render();
        // Attempt to actually generate shots via ComfyUI or AI backend
    }

    function generateShotVideo(shotIdx) {
        var state = shotState[currentChapterIdx];
        var shot = state.shots[shotIdx];
        if (!shot) return;

        showToast('正在生成分镜视频...', 'info');
        shotState[currentChapterIdx].shots[shotIdx].generatingVideo = true;
        renderShotsTab();

        var systemPrompt = '你是一个视频生成助手。';
        var userMessage = shot.frames ? shot.frames.map(function(f){ return f.description; }).join('\n') : '';

        fetch('/api/v1/ai/video/text-to-video', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ prompt: userMessage })
        })
            .then(function(r){ return r.json(); })
            .then(function(res) {
                if (res && res.success && res.data) {
                    var videoUrl = null;
                    if (res.data.urls && res.data.urls.length > 0) {
                        videoUrl = res.data.urls[0];
                    } else if (res.data.url) {
                        videoUrl = res.data.url;
                    }
                    if (videoUrl) {
                        shotState[currentChapterIdx].shots[shotIdx].videoUrl = videoUrl;
                        shotState[currentChapterIdx].shots[shotIdx].generatingVideo = false;
                        renderShotsTab();
                        showToast('视频生成完成！', 'success');
                        return;
                    }
                    if (res.data.promptId) {
                        pollAiResultForShot(res.data.promptId, 'text-to-video', shotIdx, 'video');
                        return;
                    }
                }
                shotState[currentChapterIdx].shots[shotIdx].generatingVideo = false;
                renderShotsTab();
                alert('视频生成失败: ' + (res && res.message ? res.message : '未知错误'));
            })
            .catch(function(err) {
                shotState[currentChapterIdx].shots[shotIdx].generatingVideo = false;
                renderShotsTab();
                alert('请求失败: ' + err.message);
            });
    }

    function generateStoryboardShot(shotIdx) {
        var state = shotState[currentChapterIdx];
        var shot = state.shots[shotIdx];
        if (!shot) return;

        showToast('正在生成分镜图...', 'info');
        shotState[currentChapterIdx].shots[shotIdx].generatingStoryboard = true;
        renderShotsTab();

        var description = '';
        if (shot.frames && shot.frames.length > 0) {
            description = shot.frames.map(function(f){ return f.description || ''; }).join('; ');
        }
        if (!description) description = shot.shotName || shot.shotNumber || '';

        fetch('/api/v1/ai/storyboard/generate', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ prompt: description, width: 1024, height: 576 })
        })
            .then(function(r){ return r.json(); })
            .then(function(res) {
                if (res && res.success && res.data) {
                    var imgUrl = null;
                    if (res.data.urls && res.data.urls.length > 0) {
                        imgUrl = res.data.urls[0];
                    } else if (res.data.url) {
                        imgUrl = res.data.url;
                    } else if (res.data.imageUrls && res.data.imageUrls.length > 0) {
                        imgUrl = res.data.imageUrls[0];
                    }
                    if (imgUrl) {
                        shotState[currentChapterIdx].shots[shotIdx].storyboardUrl = imgUrl;
                        shotState[currentChapterIdx].shots[shotIdx].generatingStoryboard = false;
                        renderShotsTab();
                        showToast('分镜图生成完成！', 'success');
                        return;
                    }
                    if (res.data.promptId) {
                        pollAiResultForShot(res.data.promptId, 'hidream-storyboard', shotIdx, 'storyboard');
                        return;
                    }
                }
                shotState[currentChapterIdx].shots[shotIdx].generatingStoryboard = false;
                renderShotsTab();
                alert('分镜图生成失败: ' + (res && res.message ? res.message : '未知错误'));
            })
            .catch(function(err) {
                shotState[currentChapterIdx].shots[shotIdx].generatingStoryboard = false;
                renderShotsTab();
                alert('请求失败: ' + err.message);
            });
    }

    function pollAiResultForShot(promptId, workflowType, shotIdx, resultType) {
        var pollCount = 0;
        var maxPolls = 120;
        var interval = 5000;

        var timer = setInterval(function() {
            pollCount++;
            fetch('/api/v1/ai/result/' + promptId + '?workflowType=' + encodeURIComponent(workflowType))
                .then(function(r) { return r.json(); })
                .then(function(res) {
                    if (res && res.success && res.data) {
                        clearInterval(timer);
                        var url = null;
                        if (res.data.urls && res.data.urls.length > 0) {
                            url = res.data.urls[0];
                        } else if (res.data.url) {
                            url = res.data.url;
                        }
                        if (url) {
                            if (resultType === 'video') {
                                shotState[currentChapterIdx].shots[shotIdx].videoUrl = url;
                            } else if (resultType === 'frame') {
                                shotState[currentChapterIdx].shots[shotIdx].frames[0].imagePath = url;
                                shotState[currentChapterIdx].shots[shotIdx].frames[0].hasImage = true;
                                shotState[currentChapterIdx].shots[shotIdx].hasFirstFrame = true;
                            } else if (resultType === 'storyboard') {
                                shotState[currentChapterIdx].shots[shotIdx].storyboardUrl = url;
                            }
                            shotState[currentChapterIdx].shots[shotIdx]['generating' + resultType.charAt(0).toUpperCase() + resultType.slice(1)] = false;
                            renderShotsTab();
                            if (resultType === 'video') {
                                showToast('视频生成完成！', 'success');
                            } else if (resultType === 'frame') {
                                showToast('帧图片生成完成！', 'success');
                            } else {
                                showToast('分镜图生成完成！', 'success');
                            }
                        }
                    }
                    if (pollCount >= maxPolls) {
                        clearInterval(timer);
                        renderShotsTab();
                        alert('生成超时，promptId: ' + promptId);
                    }
                })
                .catch(function() {
                    if (pollCount >= maxPolls) clearInterval(timer);
                });
        }, interval);
    }

    function generateFrameImage(shotIdx, frameIdx) {
        var state = shotState[currentChapterIdx];
        var shot = state.shots[shotIdx];
        if (!shot) return;

        var targetFrame = frameIdx >= 0 ? shot.frames[frameIdx] : null;
        var prompt = targetFrame ? targetFrame.description : (shot.frames && shot.frames[0] ? shot.frames[0].description : '');
        if (!prompt) { alert('无法获取提示词'); return; }

        showToast('正在生成帧图片...', 'info');
        shotState[currentChapterIdx].shots[shotIdx].generatingFrame = true;
        renderShotsTab();

        fetch('/api/v1/ai/image/generate', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ prompt: prompt, width: 1024, height: 576 })
        })
            .then(function(r){ return r.json(); })
            .then(function(res) {
                if (res && res.success && res.data) {
                    var imgUrl = null;
                    if (res.data.urls && res.data.urls.length > 0) {
                        imgUrl = res.data.urls[0];
                    } else if (res.data.url) {
                        imgUrl = res.data.url;
                    } else if (res.data.imageUrls && res.data.imageUrls.length > 0) {
                        imgUrl = res.data.imageUrls[0];
                    }
                    if (imgUrl) {
                        var fi = targetFrame ? frameIdx : 0;
                        if (shot.frames[fi]) {
                            shot.frames[fi].imagePath = imgUrl;
                            shot.frames[fi].hasImage = true;
                        }
                        shot.hasFirstFrame = true;
                        shotState[currentChapterIdx].shots[shotIdx].generatingFrame = false;
                        renderShotsTab();
                        showToast('帧图片生成完成！', 'success');
                        return;
                    }
                    if (res.data.promptId) {
                        pollAiResultForShot(res.data.promptId, 'text-to-image', shotIdx, 'frame');
                        return;
                    }
                }
                shotState[currentChapterIdx].shots[shotIdx].generatingFrame = false;
                renderShotsTab();
                alert('图片生成失败: ' + (res && res.message ? res.message : '未知错误'));
            })
            .catch(function(err) {
                shotState[currentChapterIdx].shots[shotIdx].generatingFrame = false;
                renderShotsTab();
                alert('请求失败: ' + err.message);
            });
    }

    function showFrameTemplates() {
        if (currentChapterIdx === -1) return;
        var ch = chapters[currentChapterIdx];
        var h = '<div style="margin-bottom:12px;"><strong>章节内容：</strong></div>'
            + '<div style="background:var(--bg);padding:12px;border-radius:6px;margin-bottom:16px;max-height:150px;overflow-y:auto;">'
            + (ch.content || '暂无内容') + '</div>';
        h += '<div style="margin-bottom:8px;"><strong>默认分帧模板：</strong></div>';
        _frameTemplates.forEach(function(t, i) {
            h += '<div style="padding:8px 12px;background:var(--bg);border-radius:6px;margin-bottom:4px;font-size:13px;">'
                + '<div>模板 ' + (i+1) + '</div>'
                + '<div style="color:var(--text2);font-size:12px;margin-top:4px;">首帧：' + t.first + '</div>'
                + '<div style="color:var(--text2);font-size:12px;">中帧：' + t.middle + '</div>'
                + '<div style="color:var(--text2);font-size:12px;">末帧：' + t.last + '</div>'
                + '</div>';
        });
        document.getElementById('frameListBody').innerHTML = h;
        document.getElementById('frameListTitle').textContent = '分帧模板';
        showModal('frameListModal');
    }

    function extractAllAssets() {
        showToast('AI 正在分析剧本提取资产...', 'info');

        var systemPrompt = '你是一个资产提取助手。请从提供的剧本内容中提取角色、道具、场景、BGM。返回 JSON 格式：{"actors":[{"name":"角色名","desc":"描述"}],"props":[{"name":"道具名","desc":"描述"}],"scenes":[{"name":"场景名","desc":"描述"}],"bgm":[{"name":"BGM名","desc":"描述"}]}。只返回 JSON，不要其他内容。';
        var allContent = chapters.map(function(c){ return '【' + c.chapterName + '】' + c.content; }).join('\n\n');

        fetch('/api/v1/ai/chat', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ userPrompt: '请从以下剧本内容中提取资产：\n\n' + allContent, systemPrompt: systemPrompt, maxLength: 4096 })
        })
            .then(function(r){ return r.json(); })
            .then(function(res) {
                if (res && res.success) {
                    try {
                        var text = res.data;
                        var match = text.match(/```(?:json)?\s*([\s\S]*?)```/);
                        var jsonText = match ? match[1].trim() : text;
                        var parsed = JSON.parse(jsonText);
                        renderExtractModal(parsed);
                        return;
                    } catch(e) {
                        console.error('解析资产 JSON 失败:', e);
                    }
                }
                renderExtractModal({ actors:[], props:[], scenes:[], bgm:[] });
            })
            .catch(function() {
                renderExtractModal({ actors:[], props:[], scenes:[], bgm:[] });
            });
    }

    function renderExtractModal(data) {
        var body = '';
        var typeNames = { actors:'角色', props:'道具', scenes:'场景', bgm:'BGM' };
        Object.keys(data).forEach(function(k) {
            var items = data[k] || [];
            body += '<div style="margin-bottom:12px;"><h4 style="font-size:13px;font-weight:600;color:var(--text3);margin-bottom:6px;">' + (typeNames[k] || k) + '</h4>';
            items.forEach(function(item, idx) {
                var itemName = item.name || item.Name || '未命名';
                var itemDesc = item.desc || item.description || item.Desc || '暂无描述';
                body += '<div class="extracted-item" style="display:flex;align-items:center;justify-content:space-between;padding:8px 12px;background:var(--bg);border-radius:6px;margin-bottom:4px;">'
                    + '<div><div class="name" style="font-weight:600;font-size:13px;">' + itemName + '</div><div class="desc" style="font-size:11px;color:var(--text3);">' + itemDesc + '</div></div>'
                    + '<label style="font-size:12px;display:flex;align-items:center;gap:6px;"><input type="checkbox" checked></label></div>';
            });
            body += '</div>';
        });
        document.getElementById('extractConfirmBody').innerHTML = body;
        showModal('extractConfirmModal');
    }

    function confirmExtractAssets() {
        hideModal('extractConfirmModal');
        showToast('资产已入库', 'success');
        // TODO: 将选中的资产调用后端 API 入库
    }

    function showImagePreview(src) {
        if (!src) return;
        window.open(src, '_blank');
    }

    function formatMarkdown(text) {
        if (!text) return '';
        return text
            .replace(/^### (.*$)/gim, '<h3>$1</h3>')
            .replace(/^## (.*$)/gim, '<h2>$1</h2>')
            .replace(/^# (.*$)/gim, '<h1>$1</h1>')
            .replace(/\*\*(.*)\*\*/gim, '<strong>$1</strong>')
            .replace(/\*(.*)\*/gim, '<em>$1</em>')
            .replace(/\n/gim, '<br>');
    }

    function showToast(msg, type) {
        var toast = document.createElement('div');
        var color = type === 'success' ? 'var(--ok)' : type === 'error' ? 'var(--danger)' : 'var(--info)';
        toast.style.cssText = 'position:fixed;top:20px;right:20px;padding:12px 20px;background:' + color + ';color:#fff;border-radius:8px;z-index:9999;font-size:13px;font-weight:600;animation:fadeIn .3s;';
        toast.textContent = msg;
        document.body.appendChild(toast);
        setTimeout(function(){ toast.remove(); }, 3000);
    }

    function showModal(id) {
        document.getElementById(id).style.display = 'flex';
    }
    function hideModal(id) {
        document.getElementById(id).style.display = 'none';
    }
</script>
}
