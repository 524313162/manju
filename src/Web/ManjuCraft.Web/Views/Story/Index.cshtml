  @{
     ViewData["Title"] = "剧本创作";
     var project = ViewBag.Project as ManjuCraft.Domain.Models.Project;
     var story = ViewBag.Story as ManjuCraft.Domain.Models.Story;
     var textProvider = ViewBag.TextProvider as dynamic;
 }

 @if (project == null || story == null)
 {
     <div class="container">
         <div class="empty-state">
             <div class="empty-state-icon">&#128196;</div>
             <p>请先选择一个项目</p>
             <a href="@Url.Action("Index", "Projects")" class="btn btn-primary" style="margin-top:16px;">返回项目管理</a>
         </div>
     </div>
     return;
 }

 <div class="prod-layout">
     <div class="story-sidebar">
         <div class="story-sidebar-header">
             <a href="@Url.Action("Index", "Projects")" class="back-link">&laquo; 返回项目</a>
             <h3 id="pName">@project.Name</h3>
             <p id="pCount">0 章节</p>
         </div>
         <div class="story-list" id="chapterList"></div>
         <div class="story-sidebar-footer"></div>
     </div>

     <div class="prod-main">
         <div class="prod-toolbar">
      <h2 id="title">剧本创作</h2>
               <div style="display:flex;gap:8px;">
                   <button class="btn btn-info btn-sm" id="aiBtn" onclick="showGenModal()">&#129302; AI 创作</button>
                   <button class="btn btn-ghost btn-sm" onclick="showImportModal()">📂 导入剧本</button>
                   <button class="btn btn-ghost btn-sm" onclick="showChapterModal(-1)">+ 添加章节</button>
                   <button class="btn btn-ghost btn-sm" onclick="showSummaryModal()">📄 故事简介</button>
               </div>
          </div>
         <div class="prod-content">
             <div id="area"></div>
         </div>
     </div>
 </div>

 <div class="modal-overlay" id="genModal">
     <div class="modal" style="width:680px;">
         <h3>&#129302; AI 一键创作剧本</h3>
         <div class="form-group">
             <label>选择 AI 提供者</label>
             <select id="providerSelect" style="width:100%;padding:8px;border:1px solid var(--border);border-radius:6px;background:var(--surface2);color:var(--text);font-size:14px;">
                 <option value="">加载中...</option>
             </select>
         </div>
         <div class="form-group">
             <label>剧本标题</label>
             <input type="text" id="storyTitle" placeholder="如：勇者传说" value="@project.Name">
         </div>
           <div class="form-group">
               <label>故事内容 / 主题描述</label>
               <textarea id="storyPrompt" rows="8" placeholder="输入你的故事主题或完整故事内容，AI 将自动生成剧本分集..."></textarea>
           </div>
          <div class="form-group">
              <label>提示词模板（可编辑）</label>
              <textarea id="genTemplate" rows="8" placeholder="加载提示词模板..."></textarea>
          </div>
         <div id="providerInfo" style="display:none;">
             <div style="padding:10px 14px;background:var(--surface2);border:1px solid var(--border);border-radius:8px;margin-bottom:12px;">
                 <span style="font-size:12px;color:var(--text3);">当前 AI 提供者：</span>
                 <span id="providerName" style="font-size:13px;font-weight:600;color:var(--text);"></span>
                 <span id="providerModel" style="font-size:12px;color:var(--text3);margin-left:8px;"></span>
             </div>
         </div>
          <div id="genResult" style="display:none;"></div>
          <div id="genActions" class="form-actions">
              <button class="btn btn-ghost" onclick="hideModal('genModal')">取消</button>
              <button class="btn btn-primary" id="genGoBtn" onclick="doAI()">开始生成</button>
          </div>
     </div>
 </div>

   <div class="modal-overlay" id="importModal">
       <div class="modal" style="width:680px;">
           <h3>📂 导入剧本</h3>
           <div class="form-group">
               <label>JSON 内容</label>
                <textarea id="importJson" rows="16" placeholder='{ "storyName": "剧本标题", "chapters": [{ "chapterName": "第一章", "content": "章节内容" }] }'></textarea>

           </div>
           <div id="importResult" style="display:none;"></div>
           <div class="form-actions">
               <button class="btn btn-ghost" onclick="hideModal('importModal')">取消</button>
               <button class="btn btn-primary" id="importGoBtn" onclick="doImport()">导入</button>
           </div>
       </div>
   </div>

  <div class="modal-overlay" id="chapterModal">
     <div class="modal" style="width:600px;">
         <h3 id="chapterModalTitle">添加章节</h3>
         <input type="hidden" id="editChapterIdx">
         <input type="hidden" id="editChapterId">
         <div class="form-group"><label>章节名称</label><input type="text" id="chName" placeholder="如：雨夜决战"></div>
          <div class="form-group"><label>章节内容</label><textarea id="chContent" rows="10" placeholder="输入本章节内容..."></textarea></div>
          <div class="form-actions">
             <button class="btn btn-ghost" onclick="hideModal('chapterModal')">取消</button>
             <button class="btn btn-primary" onclick="saveChapter()">保存</button>
         </div>
     </div>
 </div>

    <div class="modal-overlay" id="rewriteModal">
        <div class="modal" style="width:720px;">
            <h3>&#9889; AI 改写/扩写</h3>
            <input type="hidden" id="rewriteChapterIdx">
            <div class="form-group">
                <label>改写模式</label>
                <select id="rewriteMode" style="width:100%;padding:8px;border:1px solid var(--border);border-radius:6px;background:var(--surface2);color:var(--text);font-size:14px;">
                    <option value="扩写">扩写（增加细节）</option>
                    <option value="润色">润色（优化文笔）</option>
                    <option value="精简">精简（浓缩提炼）</option>
                    <option value="改写">改写（优化表达）</option>
                </select>
            </div>
            <div class="form-group">
                <label>原文内容（可手动修改）</label>
                <textarea id="rewriteOriginal" rows="10" placeholder="原文内容..."></textarea>
            </div>
            <div class="form-group">
                <label>提示词模板（可编辑）</label>
                <textarea id="rewriteTemplate" rows="6" placeholder="加载提示词模板..."></textarea>
            </div>
            <div id="rewriteResult" style="display:none;"></div>
            <div class="form-actions">
                <button class="btn btn-ghost" onclick="hideModal('rewriteModal')">取消</button>
                <button class="btn btn-primary" id="rewriteGoBtn" onclick="doRewrite()">开始改写</button>
            </div>
      </div>
   </div>

    <div class="modal-overlay" id="summaryModal">
        <div class="modal" style="width:720px;">
            <h3>📄 故事简介</h3>
            <div class="form-group">
                <label>故事名称</label>
                <div id="summaryTitleView" onclick="toggleSummaryEdit()" style="padding:12px 14px;border:1px solid var(--border);border-radius:6px;background:var(--surface2);color:var(--text);font-size:14px;cursor:pointer;line-height:1.5;" title="点击查看/编辑">暂无内容</div>
                <input type="text" id="summaryTitleInput" style="display:none;width:100%;padding:8px;border:1px solid var(--border);border-radius:6px;background:var(--surface2);color:var(--text);font-size:14px;">
            </div>
            <div class="form-group">
                <label>故事简介</label>
                <div id="summaryContentView" onclick="toggleSummaryEdit()" style="padding:12px 14px;border:1px solid var(--border);border-radius:6px;background:var(--surface2);color:var(--text);font-size:14px;cursor:pointer;line-height:1.7;max-height:300px;overflow-y:auto;white-space:pre-wrap;" title="点击查看/编辑">暂无故事简介</div>
                <textarea id="summaryContentInput" style="display:none;width:100%;padding:10px;border:1px solid var(--border);border-radius:6px;background:var(--surface2);color:var(--text);font-size:14px;resize:vertical;font-family:inherit;max-height:300px;overflow-y:auto;line-height:1.7;" rows="12"></textarea>
            </div>
            <div style="display:flex;gap:8px;justify-content:flex-end;">
                <button class="btn btn-ghost" onclick="hideModal('summaryModal')">关闭</button>
                <button class="btn btn-info" id="summaryEditBtn" onclick="toggleSummaryEdit()">编辑</button>
                <button class="btn btn-primary" id="summarySaveBtn" onclick="saveSummary()" style="display:none;">保存</button>
                <button class="btn btn-ghost" id="summaryCancelBtn" onclick="cancelSummaryEdit()" style="display:none;">取消</button>
            </div>
        </div>
    </div>

   <script>
       var projectId = @project.Id;
       var storyId = @story.Id;
       var chapters = [], ci = 0;
       var currentProvider = @Html.Raw(Json.Serialize(textProvider)) || null;
       var allProviders = [];
       var currentStoryTitle = @Json.Serialize(story.Title);
       var currentStorySummary = @Html.Raw(Json.Serialize(story.Summary ?? ""));
        var projectName = @Json.Serialize(project.Name);
   </script>
   <script src="~/js/story.js"></script>
