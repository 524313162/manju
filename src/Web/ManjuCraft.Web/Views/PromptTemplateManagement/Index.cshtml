@using ManjuCraft.Domain.Models
@{
    ViewData["Title"] = "提示词管理";
    var templates = ViewBag.Templates as List<PromptTemplate> ?? new();
    
    // 定义保留的模板类型及其中文名称和图标
    var templateTypeInfos = new Dictionary<string, (string Name, string Icon)> {
        { "SystemPrompt", ("系统提示词", "💡") },
        { "RewriteStory", ("故事重写", "🤖") },
        { "ShotAssetExtraction", ("分镜资产提取", "📋") }
    };
}

<div class="container" style="max-width:1100px;">
    <div class="page-header">
        <h2>提示词管理</h2>
        <button class="btn btn-primary btn-sm" onclick="showAddModal()">&#43; 新增模板</button>
    </div>

    <div id="templateList">
        @if (templates.Count == 0)
        {
            <div class="empty-state">
                <div class="empty-state-icon">👁</div>
                <p>暂无提示词模板，点击「新增」添加</p>
            </div>
        }
        else
        {
            foreach (var t in templates)
            {
                (string Name, string Icon) typeInfo;
                if (templateTypeInfos.ContainsKey(t.TemplateType))
                {
                    typeInfo = templateTypeInfos[t.TemplateType];
                }
                else
                {
                    typeInfo = (t.TemplateType, "📦");
                }
                var icon = typeInfo.Icon;
                var typeDisplayName = typeInfo.Name;
                var contentPreview = ((t.Content ?? "").Length > 120
                    ? (t.Content ?? "").Substring(0, 120)
                    : (t.Content ?? ""))
                    .Replace("\r\n", " ").Replace("\r", " ").Replace("\n", " ");
                <div class="res-item">
                    <div class="res-icon">@icon</div>
                    <div class="res-info">
                        <h4>@t.Name <span class="badge badge-purple" style="margin-left:8px;font-size:11px;">@typeDisplayName</span>
                        @(t.IsDefault ? " <span class=\"badge badge-ok\" style=\"font-size:11px;\">默认</span>" : "")</h4>
                        <p>@contentPreview@(t.Content != null && t.Content.Length > 120 ? "..." : "")</p>
                    </div>
                    <div class="res-actions">
                        <button class="btn btn-ghost btn-sm" data-action="edit" data-id="@t.Id">&#9998; 编辑</button>
                        <button class="btn btn-ghost btn-sm" style="color:var(--danger);" data-action="delete" data-id="@t.Id" data-name="@t.Name">&#128465; 删除</button>
                    </div>
                </div>
            }
        }
    </div>
</div>

<div class="modal-overlay" id="templateModal">
    <div class="modal" style="width:720px;">
        <div class="modal-header">
            <h3 id="templateModalTitle">新增提示词</h3>
            <button class="modal-close" onclick="hideModal('templateModal')">&times;</button>
        </div>
        <div class="modal-body">
            <input type="hidden" id="editTemplateId">
            <div class="form-group"><label>模板名称 *</label><input type="text" id="templateName" placeholder="如 系统提示词默认"></div>
            <div class="form-group"><label>类型 *</label>
                <select id="templateType">
                    @foreach (var kvp in templateTypeInfos)
                    {
                        <option value="@kvp.Key">@kvp.Value.Name</option>
                    }
                </select>
            </div>
            <div class="form-group"><label>是否默认</label>
                <select id="templateIsDefault">
                    <option value="true">是</option>
                    <option value="false">否</option>
                </select>
            </div>
            <div class="form-group"><label>提示词内容 *</label><textarea id="templateContent" rows="14" placeholder="输入提示词内容..."></textarea></div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-ghost" onclick="hideModal('templateModal')">取消</button>
            <button class="btn btn-primary" onclick="saveTemplate()">保存</button>
        </div>
    </div>
</div>

@section Scripts {
<script>
    var _templatesData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(templates.Select(t => new {
        id = t.Id,
        name = t.Name,
        templateType = t.TemplateType,
        isDefault = t.IsDefault,
        content = t.Content ?? ""
    })));
    
    // 模板类型映射（用于显示中文名称）
    var _templateTypeMap = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(templateTypeInfos.ToDictionary(k => k.Key, v => v.Value.Name)));

    function showModal(id) { document.getElementById(id).classList.add('show'); }
    function hideModal(id) { document.getElementById(id).classList.remove('show'); }
    function showToast(msg, type) { console.log(type + ': ' + msg); }

    document.addEventListener('click', function(e) {
        var btn = e.target.closest('[data-action]');
        if (!btn) return;
        var id = btn.dataset.id;
        var action = btn.dataset.action;
        if (action === 'edit') { showEditModal(id); }
        else if (action === 'delete') { deleteRes(id); }
    });

    function showAddModal() {
        document.getElementById('editTemplateId').value = '';
        document.getElementById('templateModalTitle').textContent = '新增提示词';
        document.getElementById('templateName').value = '';
        document.getElementById('templateType').value = 'SystemPrompt';
        document.getElementById('templateIsDefault').value = 'false';
        document.getElementById('templateContent').value = '';
        showModal('templateModal');
    }

    function showEditModal(id) {
        var t = _templatesData.find(function(x){ return x.id == id; });
        if (!t) return;
        document.getElementById('editTemplateId').value = t.id;
        document.getElementById('templateModalTitle').textContent = '编辑提示词';
        document.getElementById('templateName').value = t.name || '';
        document.getElementById('templateType').value = t.templateType || '';
        document.getElementById('templateIsDefault').value = t.isDefault ? 'true' : 'false';
        document.getElementById('templateContent').value = t.content || '';
        showModal('templateModal');
    }

    function saveTemplate() {
        var id = document.getElementById('editTemplateId').value;
        var name = document.getElementById('templateName').value.trim();
        var templateType = document.getElementById('templateType').value;
        var isDefault = document.getElementById('templateIsDefault').value === 'true';
        var content = document.getElementById('templateContent').value;
        if (!name) { alert('请输入名称'); return; }
        if (!content) { alert('请输入提示词内容'); return; }

        var url = '@Url.Action("Add", "PromptTemplateManagement")';
        if (id) { url = '@Url.Action("Edit", "PromptTemplateManagement")/' + id; }

        fetch(url, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name: name, templateType: templateType, content: content, isDefault: isDefault })
        })
        .then(function(r){ return r.json(); })
        .then(function(res) {
            if (res.success) {
                hideModal('templateModal');
                showToast('已保存', 'success');
                location.reload();
            } else {
                alert('保存失败：' + (res.message || ''));
            }
        });
    }

    function deleteRes(id) {
        var t = _templatesData.find(function(x){ return x.id == id; });
        var name = t ? t.name : '';
        if (!confirm('确认删除「' + name + '」？')) return;
        fetch('@Url.Action("Delete", "PromptTemplateManagement")?id=' + id, {
            method: 'POST'
        })
        .then(function(r){ return r.json(); })
        .then(function(res) {
            if (res.success) { showToast('已删除', 'success'); location.reload(); }
            else alert('删除失败');
        });
    }
</script>
}
