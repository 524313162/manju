@model List<ManjuCraft.Domain.Models.Project>
@{
    ViewData["Title"] = "项目管理";
    var hasStory = ViewBag.ProjectHasStory as HashSet<long> ?? new();
}

<div class="container">
    <div class="page-header">
        <div>
            <h2>项目管理</h2>
            <p style="font-size:14px;color:var(--text3);margin-top:4px;">管理你的漫剧项目，创建剧本、编排漫剧</p>
        </div>
        <button class="btn btn-primary" onclick="showCreateModal()">+ 新建项目</button>
    </div>

    <div class="project-grid" id="projectGrid">
        @foreach (var project in Model)
        {
            <div class="project-card">
                <div class="project-top"><h3>@project.Name</h3></div>
                <p style="font-size:13px;color:var(--text3);margin-bottom:16px;">
                    创建于 @(new DateTime(1970, 1, 1).AddMilliseconds(project.CreatedTime).ToLocalTime().ToString("yyyy-MM-dd"))
                </p>
                <div class="project-actions">
                    <button class="btn btn-primary btn-sm" onclick="goStory(@project.Id)" style="flex:1;">&#128214; 剧本创作</button>
                    @if (hasStory.Contains(project.Id))
                    {
                        <a class="btn btn-info btn-sm" href="@Url.Action("Index", "Production", new { projectId = project.Id })" style="flex:1;text-align:center;">&#9654; 漫剧创作</a>
                    }
                    else
                    {
                        <button class="btn btn-sm" style="flex:1;background:var(--border);color:var(--text3);cursor:not-allowed;text-align:center;border:none;" disabled>&#9654; 漫剧创作</button>
                    }
                    <button class="btn btn-ghost btn-sm" onclick="showEdit(@project.Id, '@project.Name')">&#9998;</button>
                    <button class="btn btn-ghost btn-sm" style="color:var(--danger);" onclick="showDelete(@project.Id, '@project.Name')">&#128465;</button>
                </div>
            </div>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <div class="empty-state-icon">&#128193;</div>
            <p>暂无项目，点击「新建项目」创建</p>
        </div>
    }
</div>

<div class="modal-overlay" id="projectModal">
    <div class="modal">
        <h3 id="projectModalTitle">新建项目</h3>
        <input type="hidden" id="editProjectId">
        <div class="form-group"><label>项目名称 *</label><input type="text" id="projName" placeholder="输入项目名称"></div>
        <div class="form-actions">
            <button class="btn btn-ghost" onclick="hideModal('projectModal')">取消</button>
            <button class="btn btn-primary" onclick="saveProject()">保存</button>
        </div>
    </div>
</div>

<div class="modal-overlay" id="deleteModal">
    <div class="modal">
        <h3 style="color:var(--danger);">&#9888; 确认删除</h3>
        <p style="font-size:14px;color:var(--text2);margin-bottom:12px;" id="deleteMessage"></p>
        <div class="form-actions">
            <button class="btn btn-ghost" onclick="hideModal('deleteModal')">取消</button>
            <button class="btn btn-danger" onclick="confirmDelete()">确认删除</button>
        </div>
    </div>
</div>

@section Scripts {
<script>
    var deleteTargetId = null;

    function goStory(projectId) {
        window.location.href = '@Url.Action("Index", "Story")?projectId=' + projectId;
    }

    function showCreateModal() {
        document.getElementById('projectModalTitle').textContent = '新建项目';
        document.getElementById('editProjectId').value = '';
        document.getElementById('projName').value = '';
        showModal('projectModal');
        setTimeout(function(){ document.getElementById('projName').focus(); }, 100);
    }

    function showEdit(id, name) {
        document.getElementById('projectModalTitle').textContent = '编辑项目';
        document.getElementById('editProjectId').value = id;
        document.getElementById('projName').value = name;
        showModal('projectModal');
    }

    function saveProject() {
        var editId = document.getElementById('editProjectId').value;
        var name = document.getElementById('projName').value.trim();
        if (!name) { alert('请输入项目名称'); return; }

        var url = editId ? '@Url.Action("Edit", "Projects")' : '@Url.Action("Create", "Projects")';
        var data = editId ? { id: editId, name: name } : { name: name };

        fetch(url, {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: new URLSearchParams(data)
        })
        .then(r => r.json())
        .then(res => {
            if (res.success) {
                hideModal('projectModal');
                showToast('已保存', 'success');
                location.reload();
            } else {
                alert(res.message);
            }
        });
    }

    function showDelete(id, name) {
        deleteTargetId = id;
        document.getElementById('deleteMessage').textContent = '确认删除项目「' + name + '」及其所有关联数据？';
        showModal('deleteModal');
    }

    function confirmDelete() {
        if (!deleteTargetId) return;
        fetch('@Url.Action("Delete", "Projects")', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: new URLSearchParams({ id: deleteTargetId })
        })
        .then(r => r.json())
        .then(res => {
            if (res.success) {
                deleteTargetId = null;
                hideModal('deleteModal');
                showToast('已删除', 'success');
                location.reload();
            }
        });
    }
</script>
}