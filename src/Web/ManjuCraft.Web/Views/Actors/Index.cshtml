@model List<ManjuCraft.Domain.Models.Asset>
@{
    ViewData["Title"] = "角色管理";
    var projectId = ViewBag.ProjectId as long?;
}

<div class="prod-layout">
    <div class="episode-sidebar">
        <div class="episode-sidebar-header">
            <a href="@Url.Action("Index", "Projects")" class="back-link">&laquo; 返回项目</a>
            <h3>角色管理</h3>
            <p id="actorCount">@Model.Count 个角色</p>
        </div>
        <div class="episode-list" id="actorSidebarList"></div>
        <div class="episode-sidebar-footer">
            <button class="btn btn-primary btn-sm" style="width:100%;" onclick="showActorModal(-1)">+ 添加角色</button>
        </div>
    </div>

    <div class="prod-main">
        <div class="prod-toolbar">
            <h2 id="mainTitle">角色管理</h2>
            <div style="display:flex;gap:8px;">
                <button class="btn btn-primary btn-sm" onclick="showActorModal(-1)">+ 添加角色</button>
            </div>
        </div>
        <div class="prod-content">
            <div id="actorList"></div>
        </div>
    </div>
</div>

<div class="modal-overlay" id="actorModal">
    <div class="modal">
        <h3 id="actorModalTitle">添加角色</h3>
        <input type="hidden" id="editActorIdx">
        <input type="hidden" id="editActorId">
        <div class="form-group"><label>角色名称 *</label><input type="text" id="actorName" placeholder="如：勇者·莲"></div>
        <div class="form-group"><label>角色描述</label><textarea id="actorDesc" rows="4" placeholder="角色的外貌特征、性格、背景故事等详细描述..."></textarea></div>
        <div class="form-actions">
            <button class="btn btn-ghost" onclick="hideModal('actorModal')">取消</button>
            <button class="btn btn-primary" onclick="saveActor()">保存</button>
        </div>
    </div>
</div>

@section Scripts {
<script>
    var actors = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Select(a => new { a.Id, a.Name, Description = a.Description ?? "" })));
    var currentIdx = -1;

    (function(){ render(); })();

    function render() {
        document.getElementById('actorCount').textContent = actors.length + ' 个角色';
        var sidebarHtml = '';
        if (actors.length === 0) {
            sidebarHtml = '<div style="padding:24px;text-align:center;color:#94a3b8;font-size:13px;">暂无角色</div>';
        } else {
            actors.forEach(function(a, i) {
                sidebarHtml += '<div class="episode-item' + (i === currentIdx ? ' active' : '') + '" onclick="currentIdx=' + i + ';render();">'
                    + '<span class="episode-num">&#127916;</span>'
                    + '<div class="episode-info"><div class="episode-name">' + a.Name + '</div></div></div>';
            });
        }
        document.getElementById('actorSidebarList').innerHTML = sidebarHtml;

        var html = '';
        if (actors.length === 0) {
            html = '<div class="empty-state"><div class="empty-state-icon">&#127916;</div><p>暂无角色，点击「添加角色」创建</p></div>';
        } else {
            actors.forEach(function(a, i) {
                html += '<div class="actor-item">'
                    + '<div class="actor-avatar" onclick="generateImage(' + i + ')" title="点击生成/替换图片">+</div>'
                    + '<div class="actor-info"><h4>' + a.Name + '</h4><p>' + (a.Description || '暂无描述') + '</p></div>'
                    + '<div class="actor-actions">'
                    + '<button class="btn btn-info btn-sm" onclick="generateImage(' + i + ')">&#127912; 生图</button>'
                    + '<button class="btn btn-ghost btn-sm" onclick="showActorModal(' + i + ')">&#9998; 编辑</button>'
                    + '<button class="btn btn-ghost btn-sm" style="color:var(--danger);" onclick="deleteActor(' + i + ')">&#128465; 删除</button>'
                    + '</div></div>';
            });
        }
        document.getElementById('actorList').innerHTML = html;
        document.getElementById('mainTitle').textContent = (currentIdx >= 0 && currentIdx < actors.length) ? actors[currentIdx].Name : '角色管理';
    }

    function showActorModal(idx) {
        document.getElementById('editActorIdx').value = idx;
        if (idx >= 0) {
            var a = actors[idx];
            document.getElementById('actorModalTitle').textContent = '编辑角色';
            document.getElementById('editActorId').value = a.Id;
            document.getElementById('actorName').value = a.Name;
            document.getElementById('actorDesc').value = a.Description || '';
        } else {
            document.getElementById('actorModalTitle').textContent = '添加角色';
            document.getElementById('editActorId').value = '';
            document.getElementById('actorName').value = '';
            document.getElementById('actorDesc').value = '';
        }
        showModal('actorModal');
    }

    function saveActor() {
        var idx = parseInt(document.getElementById('editActorIdx').value);
        var name = document.getElementById('actorName').value.trim();
        var desc = document.getElementById('actorDesc').value.trim();
        if (!name) { alert('请输入角色名称'); return; }

        var projectId = @(projectId?.ToString() ?? "null");
        var actorId = document.getElementById('editActorId').value;

        if (idx >= 0) {
            fetch('@Url.Action("Edit", "Actors")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: new URLSearchParams({ id: actorId, name: name, description: desc })
            })
            .then(r => r.json())
            .then(res => {
                if (res.success) {
                    actors[idx].Name = name;
                    actors[idx].Description = desc;
                    hideModal('actorModal');
                    showToast('角色已保存', 'success');
                    render();
                }
            });
        } else {
            fetch('@Url.Action("Create", "Actors")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: new URLSearchParams({ projectId: projectId || 0, name: name, description: desc })
            })
            .then(r => r.json())
            .then(res => {
                if (res.success) {
                    actors.push({ Id: res.data.id, Name: name, Description: desc });
                    hideModal('actorModal');
                    showToast('角色已保存', 'success');
                    currentIdx = actors.length - 1;
                    render();
                }
            });
        }
    }

    function deleteActor(idx) {
        if (!confirm('确认删除「' + actors[idx].Name + '」？')) return;
        fetch('@Url.Action("Delete", "Actors")', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: new URLSearchParams({ id: actors[idx].Id })
        })
        .then(r => r.json())
        .then(res => {
            if (res.success) {
                actors.splice(idx, 1);
                if (currentIdx >= actors.length) currentIdx = actors.length - 1;
                render();
            }
        });
    }

    function generateImage(idx) {
        showToast('正在调用 ComfyUI 生成「' + actors[idx].Name + '」角色图片...', 'info');
        setTimeout(function() {
            showToast('角色图片生成完成！', 'success');
        }, 2000);
    }
</script>
}