@using Microsoft.AspNetCore.Hosting
@using System.IO
@inject IWebHostEnvironment Environment
@{
    ViewData["Title"] = "设置";
    ViewBag.HideFooter = true;
    var dbPath = System.IO.Path.Combine(Environment.ContentRootPath, "manju.db");
    var dbFileName = "manju.db";
    var dbAbsolute = System.IO.Path.GetFullPath(dbPath);
}

<div class="container" style="max-width:1100px;">
    <div class="page-header">
        <h2>设置</h2>
    </div>

    <div class="settings-card">
        <h3>&#128451; 数据库</h3>
        <p style="font-size:14px;color:var(--text2);line-height:1.7;margin-bottom:14px;">
            SQLite 数据库存储于应用目录下：
            <code style="background:#f1f5f9;padding:2px 8px;border-radius:4px;font-size:12px;">@dbFileName</code>
        </p>
        <p style="font-size:13px;color:var(--text3);margin-bottom:16px;">
            完整路径：<code style="background:#f1f5f9;padding:2px 8px;border-radius:4px;font-size:11px;word-break:break-all;">@dbAbsolute</code>
        </p>
        <div style="display:flex;gap:10px;margin-top:16px;">
            <a href="@Url.Action("DownloadDb", "Settings")" class="btn btn-outline btn-sm">
                &#11015; 下载数据库文件
            </a>
        </div>
    </div>
</div>

@section Scripts {
}
