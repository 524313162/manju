<!DOCTYPE html>
<html lang="zh-CN">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] — ManjuCraft</title>
    <link rel="stylesheet" href="~/css/style.css">
    @RenderSection("Styles", required: false)
</head>

<body>
    <nav class="navbar">
        <div class="nav-left">
            <a href="@Url.Action("Index", "Home")"
               style="display:flex;align-items:baseline;gap:14px;text-decoration:none;">
                <h1 class="logo">ManjuCraft</h1>
                <span class="subtitle">漫剧开发工具</span>
            </a>
        </div>
        <div class="nav-right">
            <a href="@Url.Action("Index", "Projects")"
               class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Projects" ? "active" : "")">项目管理</a>
            <a href="@Url.Action("Index", "Story")"
               class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Story" ? "active" : "")">剧本创作</a>
            <a href="@Url.Action("Index", "Production")"
               class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Production" ? "active" : "")">漫剧创作</a>
            <a href="javascript:void(0)" onclick="goAssets()"
               class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Assets" ? "active" : "")">资产管理</a>
            <a href="@Url.Action("Index", "ApiManagement")"
               class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "ApiManagement" ? "active" : "")">API 管理</a>
            <a href="@Url.Action("Index", "PromptTemplateManagement")"
               class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "PromptTemplateManagement" ? "active" : "")">提示词管理</a>
            <a href="@Url.Action("Index", "Settings")"
               class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Settings" ? "active" : "")">设置</a>
        </div>
    </nav>

    <main style="min-height:calc(100vh - 62px);">
        @RenderBody()
    </main>

    @if (ViewBag.HideFooter != true)
    {
        <footer class="footer">
            <p>ManjuCraft v20260629 — 漫剧 AI 创作平台</p>
        </footer>
    }

    <script>
    function showModal(id){document.getElementById(id).classList.add('show');}
    function hideModal(id){document.getElementById(id).classList.remove('show');}
    function showToast(msg,type){
        type=type||'info';
        var bg=type==='success'?'#d1fae5':type==='error'?'#fee2e2':'#e0e7ff';
        var txt=type==='success'?'#15803d':type==='error'?'#b91c1c':'#4338ca';
        var toast=document.createElement('div');
        toast.style.cssText='position:fixed;top:80px;right:24px;background:'+bg+';color:'+txt+';padding:14px 24px;border-radius:8px;font-size:14px;font-weight:600;z-index:9999;box-shadow:0 8px 24px rgba(0,0,0,.12);';
        toast.textContent=msg;
        document.body.appendChild(toast);
        setTimeout(function(){toast.remove();},3000);
    }
    function tryJson(str,def){if(!str)return def;try{return JSON.parse(str)}catch(e){return def}}
    function goAssets() {
        var lastProj = localStorage.getItem('selectedProjectId');
        if (lastProj) {
            window.location.href = '@Url.Action("Index", "Assets")?projectId=' + lastProj;
        } else {
            window.location.href = '@Url.Action("Index", "Projects")';
        }
    }
    </script>
    <script src="~/js/main.js"></script>
    @RenderSection("Scripts", required: false)
</body>

</html>