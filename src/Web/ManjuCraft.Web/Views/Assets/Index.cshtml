@using ManjuCraft.Domain.Models
@using System.Text.Json
@{
    ViewData["Title"] = "资产管理";
    var projectId = ViewBag.ProjectId as long?;
    var assetType = ViewBag.Type as AssetTypeEnum? ?? AssetTypeEnum.Actor;
    var typeName = ViewBag.TypeName as string ?? "角色";
    var projects = ViewBag.Projects as List<Project> ?? new();
    var assets = ViewBag.Assets as List<Asset> ?? new();
}

@functions {
    string GetEmoji(AssetTypeEnum t) => t switch {
        AssetTypeEnum.Actor => char.ConvertFromUtf32(0x1F464),
        AssetTypeEnum.Scene => char.ConvertFromUtf32(0x1F3D0),
        AssetTypeEnum.Bgm => char.ConvertFromUtf32(0x1F3A5),
        AssetTypeEnum.Prop => "\uD83D\uDD25",
        _ => char.ConvertFromUtf32(0x1F4AA)
    };
    string GetBgColor(AssetTypeEnum t) => t switch {
        AssetTypeEnum.Actor => "linear-gradient(135deg, #667eea 0%, #764ba2 100%)",
        AssetTypeEnum.Scene => "linear-gradient(135deg, #11998e 0%, #38ef7d 100%)",
        AssetTypeEnum.Bgm => "linear-gradient(135deg, #f093fb 0%, #f5576c 100%)",
        AssetTypeEnum.Prop => "linear-gradient(135deg, #a18cd1 0%, #fbc2eb 100%)",
        AssetTypeEnum.VoiceVoice => "linear-gradient(135deg, #4facfe 0%, #00f2fe 100%)",
        _ => "linear-gradient(135deg, #868f96 0%, #596164 100%)"
    };
}

<div class="container">
    <div class="assets-topbar">
        <div class="assets-topbar-left">
            <label for="projectSelect">&#128233; 当前项目：</label>
            <select id="projectSelect" onchange="switchProject(this.value)">
                @foreach (var p in projects)
                {
                    <option value="@p.Id" selected="@(p.Id == projectId)">@p.Name</option>
                }
            </select>
        </div>
        <div class="assets-topbar-right">
            <div class="assets-search">
                <svg class="search-icon" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor"
                     stroke-width="2">
                    <circle cx="11" cy="11" r="8" />
                    <path d="M21 21l-4.35-4.35" />
                </svg>
                <input type="text" id="searchInput" placeholder="搜索资产名称..." oninput="filterAssets()">
            </div>
            <button class="btn btn-primary" onclick="showAddModal(false)">+ 添加</button>
            <button class="btn btn-ghost" onclick="showAssetImportModal()">📂 批量导入</button>
            <button class="btn btn-danger" onclick="clearAllAssets()" style="margin-left:4px;">🗑️ 清除所有资产</button>
        </div>
    </div>

    <div class="asset-type-grid">
        @foreach (var t in new[] { AssetTypeEnum.Actor, AssetTypeEnum.Prop, AssetTypeEnum.Scene, AssetTypeEnum.Bgm, AssetTypeEnum.VoiceVoice })
        {
            <a href="?type=@((int)t)&projectId=@projectId" class="asset-type-card @(assetType == t ? "active" : "")" data-type="@t.ToString()">
                <div class="asset-type-icon actor-icon">@GetEmoji(t)</div>
                <div class="asset-type-content">
                    <div class="asset-type-name">@t.DisplayName()</div>
                    <div class="asset-type-count">@t.DisplayName()资产</div>
                </div>
            </a>
        }
    </div>

    <div class="assets-page-header">
        <div>
            <h2>
                <span class="header-emoji" style="margin-right:6px;">@(GetEmoji(assetType))</span>
                <span>@typeName</span>
            </h2>
            <p>管理@typeName资产，为生成和绑定做准备</p>
        </div>
        <button class="btn btn-primary btn-lg" onclick="showAddModal(true)">+ 新增值项</button>
    </div>

    <div id="assetList">
        @if (assets.Count == 0)
        {
            <div class="empty-state">
                <div class="empty-state-icon">&#128228;</div>
                <p>暂无@typeName资产</p>
                <button class="btn btn-primary" style="margin-top:16px;" onclick="showAddModal(true)">+ 添加第一个 @typeName</button>
            </div>
        }
        else
        {
            <div class="assets-card-grid">
                @foreach (var a in assets)
                {
                    var emoji = GetEmoji(a.AssetType);
                    var bgGradient = GetBgColor(a.AssetType);
                    var imgSrc = a.Resource != null && !string.IsNullOrEmpty(a.Resource.FilePath) ? "/" + a.Resource.FilePath : "";
                    var isBgm = a.AssetType == AssetTypeEnum.Bgm;
                    var extension = "";
                    if (!string.IsNullOrEmpty(imgSrc))
                    {
                        var parts = imgSrc.Split('.');
                        if (parts.Length > 1) extension = "." + parts[parts.Length - 1];
                    }
                    var badgeClass = a.AssetType == AssetTypeEnum.Scene ? "type-scene" : a.AssetType == AssetTypeEnum.Bgm ? "type-bgm" : a.AssetType == AssetTypeEnum.Prop ? "type-prop" : a.AssetType == AssetTypeEnum.VoiceVoice ? "type-voicevoice" : "type-actor";
                    <div class="asset-detail-card" data-type="@a.AssetType.ToString()" data-imgsrc="@imgSrc" data-isbgm="@(isBgm.ToString().ToLower())" data-parentid="@a.ParentId?.ToString()">
                        @if (isBgm)
                        {
                            <div class="asset-image-placeholder bgm-card @(string.IsNullOrEmpty(imgSrc) ? "has-placeholder" : "")" onclick="showReplaceModalFromClick(@a.Id, '@a.Name.Replace("'", "\\'")', true)">
                                <div class="bgm-icon">🎵</div>
                                @if (!string.IsNullOrEmpty(imgSrc))
                                {
                                    <audio id="audio-@a.Id" src="@imgSrc"></audio>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="asset-image-placeholder @(string.IsNullOrEmpty(imgSrc) ? "has-placeholder" : "")" @if (string.IsNullOrEmpty(imgSrc)) { <text>onclick="showReplaceModalFromClick(@a.Id, '@a.Name.Replace("'", "\\'")', false)"</text> }>
                                @if (!string.IsNullOrEmpty(imgSrc))
                                {
                                    <img src="@imgSrc" alt="@a.Name" onclick="event.stopPropagation(); showImagePreview(this.src, '@a.Name.Replace("'", "\\'")')" style="cursor:zoom-in;" />
                                }
                                else
                                {
                                    <div class="placeholder-icon" style="background:@bgGradient;">@emoji</div>
                                }
                            </div>
                        }
                        <div class="asset-detail-header">
                            <div class="asset-detail-type @(badgeClass)">@(a.AssetType)</div>
                            <div class="asset-detail-order">No. @(a.Order)</div>
                        </div>
                        <div class="asset-detail-name">@a.Name</div>
                        <div class="asset-detail-desc">@(a.Description ?? "暂无描述")</div>
        <div class="asset-detail-actions">
                            <button type="button" class="action-btn action-ai" data-id="@a.Id" data-type="@a.AssetType.ToString()" data-name='@Json.Serialize(a.Name)' data-url="@imgSrc" data-isbgm="@(isBgm.ToString().ToLower())">
                                <span class="action-icon">&#129302;</span> AI 生成
                            </button>
                            <button type="button" class="action-btn action-edit" data-id="@a.Id" data-type="@a.AssetType.ToString()" data-name='@Json.Serialize(a.Name)' data-desc='@Json.Serialize(a.Description)' data-order="@a.Order" data-imgsrc="@imgSrc" data-isbgm="@(isBgm.ToString().ToLower())">
                                <span class="action-icon">&#9998;</span> 编辑
                            </button>
                            <button type="button" class="action-btn action-delete" data-id="@a.Id" data-name='@Json.Serialize(a.Name)'>
                                <span class="action-icon">&#128465;</span>
                            </button>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<div class="modal-overlay" id="assetImportModal">
    <div class="modal" style="width:640px;">
        <div class="modal-header">
            <h3>📂 批量导入资产</h3>
            <button class="modal-close" onclick="hideModal('assetImportModal')">&times;</button>
        </div>
        <div class="modal-body">
            <div class="form-group">
                <label>当前项目</label>
                <div style="padding:8px 10px;border:1.5px solid var(--border);border-radius:var(--radius-sm);font-size:14px;font-weight:600;background:var(--bg);">@ViewBag.ProjectName</div>
            </div>
            <div class="form-group">
                <label>粘贴 JSON 资产数据</label>
                <textarea id="assetImportJson" rows="14" placeholder='[
  {
    "assetType": "Actor",
    "name": "角色名",
    "description": "描述"
  },
  {
    "assetType": "VoiceVoice",
    "name": "角色声线",
    "description": "描述",
    "belong": "角色名"
  }
]' style="font-family:monospace;font-size:12px;"></textarea>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-ghost" onclick="hideModal('assetImportModal')">取消</button>
            <button class="btn btn-primary" onclick="doAssetImport()">导入并合并</button>
        </div>
    </div>
</div>

<div class="modal-overlay" id="assetImportMergeModal">
    <div class="modal" style="width:760px;max-height:92vh;">
        <div class="modal-header">
            <h3>📂 导入资产 - 合并确认</h3>
            <button class="modal-close" onclick="hideModal('assetImportMergeModal')">&times;</button>
        </div>
        <div class="modal-body">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;">
                <p style="font-size:13px;color:var(--text2);margin:0;">勾选需要保存或覆盖的资产，已存在的资产默认不勾选，手动勾选后将覆盖原有内容。</p>
                <button class="btn btn-xs btn-ghost" onclick="copyAssetImportJson()" style="white-space:nowrap;">📋 复制 JSON</button>
            </div>
            <div id="assetImportMergeList" style="max-height:400px;overflow-y:auto;"></div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-ghost" onclick="hideModal('assetImportMergeModal')">取消</button>
            <button class="btn btn-primary" id="assetImportMergeSaveBtn" onclick="saveAssetImportMerge()">保存勾选</button>
        </div>
    </div>
</div>

<div class="modal-overlay" id="assetModal">
    <div class="modal modal-medium">
        <div class="modal-header">
            <h3 id="assetModalTitle">添加角色</h3>
            <button class="modal-close" onclick="hideModal('assetModal')">&times;</button>
        </div>
        <input type="hidden" id="editAssetId">
        <div class="modal-body">
            <div class="form-group"><label>类型 *</label>
                <select id="assetTypeSelect">
                    <option value="Actor">角色</option>
                    <option value="Scene">场景</option>
                    <option value="Prop">道具</option>
                    <option value="Bgm">BGM</option>
                    <option value="VoiceVoice">声音</option>
                </select>
            </div>
            <div class="form-group" id="parentSelectGroup" style="display:none;"><label>父节点（所属角色/道具）*</label><select id="assetParentId"><option value="">请选择父资产...</option></select></div>
            <div class="form-group"><label>名称 *</label><input type="text" id="assetName" placeholder="输入名称"></div>
            <div class="form-group"><label>描述</label><textarea id="assetDesc" rows="3" placeholder="详细描述..."></textarea></div>
            <div class="form-group"><label>排序</label><input type="number" id="assetOrder" value="0" min="0"></div>
            <div class="form-group" id="resourcePreviewGroup" style="display:none">
                <label>当前资源图片</label>
                <div id="resourcePreview" style="text-align:center;padding:10px;">
                    <img id="resourcePreviewImg" src="" style="max-width:100%;max-height:200px;object-fit:contain;border-radius:8px;display:none;" onclick="showImagePreview(this.src, document.getElementById('resourcePreviewTitle').textContent)" />
                    <div id="resourceNoImage" style="color:#888;font-size:13px;">暂无资源图片</div>
                    <div id="resourcePreviewTitle" style="display:none"></div>
                </div>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-ghost" onclick="hideModal('assetModal')">取消</button>
            <button class="btn btn-primary" id="saveAssetBtn" onclick="saveAsset()">保存</button>
        </div>
    </div>
</div>

<div class="modal-overlay" id="replaceResourceModal">
    <div class="modal modal-medium">
        <div class="modal-header">
            <h3 id="replaceResourceTitle">替换图片</h3>
            <button class="modal-close" onclick="hideModal('replaceResourceModal')">&times;</button>
        </div>
        <input type="hidden" id="replaceAssetId">
        <div class="modal-body">
            <input type="file" id="replaceFileInput" accept="image/*" style="padding:8px;text-align:left;width:100%;">
            <div id="replacePreview" style="text-align:center;padding:10px;">
                <img id="replacePreviewImg" src="" style="max-width:100%;max-height:200px;object-fit:contain;border-radius:8px;display:none;">
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-ghost" onclick="hideModal('replaceResourceModal')">取消</button>
            <button class="btn btn-primary" onclick="uploadReplace()">上传替换</button>
        </div>
    </div>
</div>

<!-- 单个资产 AI 图片生成模态框 (新版: 角色+道具+场景) -->
<div class="modal-overlay" id="singleAssetGenModal">
    <div class="modal modal-large" style="width:900px;">
        <div class="modal-header">
            <h3 id="singleAssetGenTitle">单个资产 AI 生成图片</h3>
            <button class="modal-close" onclick="hideModal('singleAssetGenModal')">&times;</button>
        </div>
        <input type="hidden" id="sagAssetId">
        <input type="hidden" id="sagAssetType">
        <input type="hidden" id="sagAssetName">
        <input type="hidden" id="sagGeneratedImageUrl">
        <div class="modal-body">
            <!-- 第1行: 选择大模型 -->
            <div class="form-group">
                <label>选择生成模型 *</label>
                <select id="sagModelSelect" class="form-control">
                    <option value="">加载中...</option>
                </select>
            </div>
            <!-- 第2行: 模板提示词 (可编辑) -->
            <div class="form-group" id="sagTemplateGroup" style="display:none;">
                <label>系统模板提示词</label>
                <textarea id="sagTemplatePromptDisplay" rows="8" style="font-family:monospace;font-size:12px;"></textarea>
            </div>
            <!-- 第3行: 用户提示词 -->
            <div class="form-group">
                <label>生成提示词 *</label>
                <textarea id="sagPrompt" rows="4" placeholder="描述你想要生成的图片内容..."></textarea>
                <div class="form-hint" id="sagPromptHint" style="font-size:12px;color:var(--text3);margin-top:4px;"></div>
            </div>
            <!-- 第3行: 预览区域 (生成后显示) -->
            <div class="form-group" id="sagPreviewGroup" style="display:none;">
                <label>生成预览</label>
                <div id="sagPreviewContainer" style="text-align:center;padding:16px;background:#fafafa;border-radius:8px;border:1px solid var(--border);min-height:200px;display:flex;align-items:center;justify-content:center;">
                    <div id="sagPreviewPlaceholder" style="color:#999;">生成后将在此显示预览</div>
                    <img id="sagPreviewImg" src="" style="max-width:100%;max-height:400px;object-fit:contain;border-radius:8px;display:none;box-shadow:0 4px 16px rgba(0,0,0,0.1);" />
                </div>
            </div>
            <!-- 第4行: 操作按钮 -->
            <div class="form-group" id="sagActionGroup">
                <div style="display:flex;gap:12px;justify-content:flex-end;">
                    <button class="btn btn-ghost" id="sagCloseBtn" onclick="hideModal('singleAssetGenModal')">关闭</button>
                    <button class="btn btn-primary" id="sagGenerateBtn" onclick="doSingleAssetGenerate()">生成</button>
                    <button class="btn btn-success" id="sagSaveBtn" onclick="saveSingleAssetImage()" style="display:none;">保存到资产</button>
                </div>
            </div>
            <div id="sagStatus" style="margin-top:12px;padding:12px;border-radius:8px;display:none;"></div>
        </div>
    </div>
</div>

<div class="modal-overlay" id="imagePreviewModal" onclick="hideModal('imagePreviewModal')" style="background:rgba(0,0,0,0.6);padding:0;overflow:hidden;">
    <div style="display:flex;align-items:center;justify-content:center;width:100vw;height:100vh;padding:0;margin:0;overflow:hidden;">
        <img id="previewImage" src="" style="max-width:100vw;max-height:100vh;width:auto;height:auto;object-fit:contain;" />
    </div>
</div>

@section Scripts {
    @{
        var cacheBust = DateTimeOffset.UtcNow.ToUnixTimeSeconds();
    }
    <script src="~/js/main.js"></script>
    <script src="~/js/assets-core.js"></script>
    <script src="~/js/production-utils.js"></script>
    <script src="~/js/assets-api.js"></script>
    <script src="~/js/assets-modal.js"></script>
    <script src="~/js/assets-render.js"></script>
    <script src="~/js/assets.js"
            data-project-id="@(projectId.HasValue ? projectId.Value : 0)"
            data-current-type="@((int)assetType)"
            data-type-name="@typeName"></script>
}