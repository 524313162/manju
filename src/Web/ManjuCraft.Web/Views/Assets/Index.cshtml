@using ManjuCraft.Domain.Models
@using System.Text.Json
@{
    ViewData["Title"] = "资产管理";
    var projectId = ViewBag.ProjectId as long?;
    var assetType = ViewBag.Type as AssetTypeEnum? ?? AssetTypeEnum.Actor;
    var typeName = ViewBag.TypeName as string ?? "角色";
    var projects = ViewBag.Projects as List<Project> ?? new();
    var assets = ViewBag.Assets as List<Asset> ?? new();
}

@functions {
    string GetEmoji(AssetTypeEnum t) => t switch {
        AssetTypeEnum.Actor => char.ConvertFromUtf32(0x1F464),
        AssetTypeEnum.Scene => char.ConvertFromUtf32(0x1F3D0),
        AssetTypeEnum.Bgm => char.ConvertFromUtf32(0x1F3A5),
        AssetTypeEnum.Prop => "\uD83D\uDD25",
        _ => char.ConvertFromUtf32(0x1F4AA)
    };
    string GetBgColor(AssetTypeEnum t) => t switch {
        AssetTypeEnum.Actor => "linear-gradient(135deg, #667eea 0%, #764ba2 100%)",
        AssetTypeEnum.Scene => "linear-gradient(135deg, #11998e 0%, #38ef7d 100%)",
        AssetTypeEnum.Bgm => "linear-gradient(135deg, #f093fb 0%, #f5576c 100%)",
        AssetTypeEnum.Prop => "linear-gradient(135deg, #a18cd1 0%, #fbc2eb 100%)",
        AssetTypeEnum.VoiceVoice => "linear-gradient(135deg, #4facfe 0%, #00f2fe 100%)",
        _ => "linear-gradient(135deg, #868f96 0%, #596164 100%)"
    };
}

<div class="container">
    <div class="assets-topbar">
        <div class="assets-topbar-left">
            <label for="projectSelect">&#128233; 当前项目：</label>
            <select id="projectSelect" onchange="switchProject(this.value)">
                @foreach (var p in projects)
                {
                    <option value="@p.Id" selected="@(p.Id == projectId)">@p.Name</option>
                }
            </select>
        </div>
        <div class="assets-topbar-right">
            <div class="assets-search">
                <svg class="search-icon" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor"
                     stroke-width="2">
                    <circle cx="11" cy="11" r="8" />
                    <path d="M21 21l-4.35-4.35" />
                </svg>
                <input type="text" id="searchInput" placeholder="搜索资产名称..." oninput="filterAssets()">
            </div>
            <button class="btn btn-primary" onclick="showAddModal()">+ 添加</button>
            <button class="btn btn-ghost" onclick="showAssetImportModal()">📂 批量导入</button>
            <button class="btn btn-danger" onclick="clearAllAssets()" style="margin-left:4px;">🗑️ 清除所有资产</button>
        </div>
    </div>

    <div class="asset-type-grid">
        @foreach (var t in new[] { AssetTypeEnum.Actor, AssetTypeEnum.Prop, AssetTypeEnum.Scene, AssetTypeEnum.Bgm, AssetTypeEnum.VoiceVoice })
        {
            <a href="?type=@((int)t)&projectId=@projectId" class="asset-type-card @(assetType == t ? "active" : "")" data-type="@t.ToString()">
                <div class="asset-type-icon actor-icon">@GetEmoji(t)</div>
                <div class="asset-type-content">
                    <div class="asset-type-name">@t.DisplayName()</div>
                    <div class="asset-type-count">@t.DisplayName()资产</div>
                </div>
            </a>
        }
    </div>

    <div class="assets-page-header">
        <div>
            <h2>
                <span class="header-emoji" style="margin-right:6px;">@(GetEmoji(assetType))</span>
                <span>@typeName</span>
            </h2>
            <p>管理@typeName资产，为生成和绑定做准备</p>
        </div>
        <button class="btn btn-primary btn-lg" onclick="showAddModal()">+ 新增值项</button>
    </div>

    <div id="assetList">
        @if (assets.Count == 0)
        {
            <div class="empty-state">
                <div class="empty-state-icon">&#128228;</div>
                <p>暂无@typeName资产</p>
                <button class="btn btn-primary" style="margin-top:16px;" onclick="showAddModal()">+ 添加第一个 @typeName</button>
            </div>
        }
        else
        {
            <div class="assets-card-grid">
                @foreach (var a in assets)
                {
                    var emoji = GetEmoji(a.AssetType);
                    var bgGradient = GetBgColor(a.AssetType);
                    var imgSrc = a.Resource != null && !string.IsNullOrEmpty(a.Resource.FilePath) ? "/" + a.Resource.FilePath : "";
                    var isBgm = a.AssetType == AssetTypeEnum.Bgm;
                    var extension = "";
                    if (!string.IsNullOrEmpty(imgSrc))
                    {
                        var parts = imgSrc.Split('.');
                        if (parts.Length > 1) extension = "." + parts[parts.Length - 1];
                    }
                    var badgeClass = a.AssetType == AssetTypeEnum.Scene ? "type-scene" : a.AssetType == AssetTypeEnum.Bgm ? "type-bgm" : a.AssetType == AssetTypeEnum.Prop ? "type-prop" : a.AssetType == AssetTypeEnum.VoiceVoice ? "type-voicevoice" : "type-actor";
                    <div class="asset-detail-card" data-type="@a.AssetType.ToString()" data-imgsrc="@imgSrc" data-isbgm="@(isBgm.ToString().ToLower())" data-parentid="@a.ParentId?.ToString()">
                        @if (isBgm)
                        {
                            <div class="asset-image-placeholder bgm-card @(string.IsNullOrEmpty(imgSrc) ? "has-placeholder" : "")" onclick="showReplaceModalFromClick(@a.Id, '@a.Name.Replace("'", "\\'")', true)">
                                <div class="bgm-icon">🎵</div>
                                @if (!string.IsNullOrEmpty(imgSrc))
                                {
                                    <audio id="audio-@a.Id" src="@imgSrc"></audio>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="asset-image-placeholder @(string.IsNullOrEmpty(imgSrc) ? "has-placeholder" : "")" onclick="showReplaceModalFromClick(@a.Id, '@a.Name.Replace("'", "\\'")', false)">
                                @if (!string.IsNullOrEmpty(imgSrc))
                                {
                                    <img src="@imgSrc" alt="@a.Name" />
                                }
                                else
                                {
                                    <div class="placeholder-icon" style="background:@bgGradient;">@emoji</div>
                                }
                            </div>
                        }
                        <div class="asset-detail-header">
                            <div class="asset-detail-type @(badgeClass)">@(a.AssetType)</div>
                            <div class="asset-detail-order">No. @(a.Order)</div>
                        </div>
                        <div class="asset-detail-name">@a.Name</div>
                        <div class="asset-detail-desc">@(a.Description ?? "暂无描述")</div>
        <div class="asset-detail-actions">
                            <button type="button" class="action-btn action-ai" data-id="@a.Id" data-type="@a.AssetType.ToString()" data-name='@Json.Serialize(a.Name)' data-url="@imgSrc" data-isbgm="@(isBgm.ToString().ToLower())">
                                <span class="action-icon">&#129302;</span> AI 生成
                            </button>
                            <button type="button" class="action-btn action-edit" data-id="@a.Id" data-name='@Json.Serialize(a.Name)' data-desc='@Json.Serialize(a.Description)' data-order="@a.Order" data-imgsrc="@imgSrc" data-isbgm="@(isBgm.ToString().ToLower())">
                                <span class="action-icon">&#9998;</span> 编辑
                            </button>
                            @if (a.AssetType == AssetTypeEnum.Actor)
                            {
                            }
                            <button type="button" class="action-btn action-delete" data-id="@a.Id" data-name='@Json.Serialize(a.Name)'>
                                <span class="action-icon">&#128465;</span>
                            </button>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<div class="modal-overlay" id="assetImportModal">
    <div class="modal" style="width:640px;">
        <div class="modal-header">
            <h3>📂 批量导入资产</h3>
            <button class="modal-close" onclick="hideModal('assetImportModal')">&times;</button>
        </div>
        <div class="modal-body">
            <div class="form-group">
                <label>当前项目</label>
                <div style="padding:8px 10px;border:1.5px solid var(--border);border-radius:var(--radius-sm);font-size:14px;font-weight:600;background:var(--bg);">@ViewBag.ProjectName</div>
            </div>
            <div class="form-group">
                <label>粘贴 JSON 资产数据</label>
                <textarea id="assetImportJson" rows="14" placeholder='[
  {
    "assetType": "Actor",
    "name": "角色名",
    "description": "描述"
  },
  {
    "assetType": "VoiceVoice",
    "name": "角色声线",
    "description": "描述",
    "belong": "角色名"
  }
]' style="font-family:monospace;font-size:12px;"></textarea>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-ghost" onclick="hideModal('assetImportModal')">取消</button>
            <button class="btn btn-primary" onclick="doAssetImport()">导入并合并</button>
        </div>
    </div>
</div>

<div class="modal-overlay" id="assetImportMergeModal">
    <div class="modal" style="width:760px;max-height:92vh;">
        <div class="modal-header">
            <h3>📂 导入资产 - 合并确认</h3>
            <button class="modal-close" onclick="hideModal('assetImportMergeModal')">&times;</button>
        </div>
        <div class="modal-body">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;">
                <p style="font-size:13px;color:var(--text2);margin:0;">勾选需要保存或覆盖的资产，已存在的资产默认不勾选，手动勾选后将覆盖原有内容。</p>
                <button class="btn btn-xs btn-ghost" onclick="copyAssetImportJson()" style="white-space:nowrap;">📋 复制 JSON</button>
            </div>
            <div id="assetImportMergeList" style="max-height:400px;overflow-y:auto;"></div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-ghost" onclick="hideModal('assetImportMergeModal')">取消</button>
            <button class="btn btn-primary" id="assetImportMergeSaveBtn" onclick="saveAssetImportMerge()">保存勾选</button>
        </div>
    </div>
</div>

<div class="modal-overlay" id="assetModal">
    <div class="modal modal-medium">
        <div class="modal-header">
            <h3 id="assetModalTitle">添加角色</h3>
            <button class="modal-close" onclick="hideModal('assetModal')">&times;</button>
        </div>
        <input type="hidden" id="editAssetId">
        <div class="modal-body">
            <div class="form-group" id="parentSelectGroup" style="display:none;"><label>父节点（所属角色/道具）*</label><select id="assetParentId"><option value="">请选择父资产...</option></select></div>
            <div class="form-group"><label>名称 *</label><input type="text" id="assetName" placeholder="输入名称"></div>
            <div class="form-group"><label>描述</label><textarea id="assetDesc" rows="3" placeholder="详细描述..."></textarea></div>
            <div class="form-group"><label>排序</label><input type="number" id="assetOrder" value="0" min="0"></div>
            <div class="form-group" id="resourcePreviewGroup" style="display:none">
                <label>当前资源图片</label>
                <div id="resourcePreview" style="text-align:center;padding:10px;">
                    <img id="resourcePreviewImg" src="" style="max-width:100%;max-height:200px;object-fit:contain;border-radius:8px;display:none;" onclick="showImagePreview(this.src, document.getElementById('resourcePreviewTitle').textContent)" />
                    <div id="resourceNoImage" style="color:#888;font-size:13px;">暂无资源图片</div>
                    <div id="resourcePreviewTitle" style="display:none"></div>
                </div>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-ghost" onclick="hideModal('assetModal')">取消</button>
            <button class="btn btn-primary" onclick="saveAsset()">保存</button>
        </div>
    </div>
</div>

<div class="modal-overlay" id="replaceResourceModal">
    <div class="modal modal-medium">
        <div class="modal-header">
            <h3 id="replaceResourceTitle">替换图片</h3>
            <button class="modal-close" onclick="hideModal('replaceResourceModal')">&times;</button>
        </div>
        <input type="hidden" id="replaceAssetId">
        <div class="modal-body">
            <input type="file" id="replaceFileInput" accept="image/*" style="padding:8px;text-align:left;width:100%;">
            <div id="replacePreview" style="text-align:center;padding:10px;">
                <img id="replacePreviewImg" src="" style="max-width:100%;max-height:200px;object-fit:contain;border-radius:8px;display:none;">
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-ghost" onclick="hideModal('replaceResourceModal')">取消</button>
            <button class="btn btn-primary" onclick="uploadReplace()">上传替换</button>
        </div>
    </div>
</div>

<!-- AI 生成模态框 -->
<div class="modal-overlay" id="aiGenerateModal">
    <div class="modal modal-medium">
        <div class="modal-header">
            <h3 id="aiGenerateTitle">AI 生成</h3>
            <button class="modal-close" onclick="hideModal('aiGenerateModal')">&times;</button>
        </div>
        <input type="hidden" id="aiAssetId">
        <input type="hidden" id="aiAssetType">
        <input type="hidden" id="aiAssetName">
        <div class="modal-body">
            <div class="form-group">
                <label>AI 生成提示词 *</label>
                <textarea id="aiGenPrompt" rows="4" placeholder="描述你想要生成的内容..."></textarea>
            </div>
            <div id="aiGenExtraFields"></div>
            <div id="aiGenResult" style="display:none;"></div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-ghost" onclick="hideModal('aiGenerateModal')">取消</button>
            <button class="btn btn-primary" id="aiGenBtn" onclick="doAiGenerate()">开始生成</button>
        </div>
    </div>
</div>

<div class="modal-overlay" id="imagePreviewModal" onclick="hideModal('imagePreviewModal')">
    <div class="modal" style="width:90vw;max-width:1400px;height:90vh;background:transparent;box-shadow:none;align-items:center;justify-content:center;">
        <div style="text-align:center;">
            <h3 id="previewImageTitle" style="color:#fff;margin-bottom:16px;"></h3>
            <div id="previewImageContainer" style="display:inline-block;max-height:85vh;">
                <img id="previewImage" src="" style="max-width:100%;max-height:80vh;object-fit:contain;border-radius:12px;box-shadow:0 8px 32px rgba(0,0,0,0.4);" />
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var projectId = parseInt('@(projectId ?? 0L)');
        var currentType = @(assetType.GetHashCode());
        var typeName = '@typeName';

        function switchProject(pid) {
            window.location.href = '?type=' + currentType + '&projectId=' + pid;
        }

        function filterAssets() {
            var query = document.getElementById('searchInput').value.toLowerCase().trim();
            var cards = document.querySelectorAll('#assetList .asset-detail-card');
            cards.forEach(function(card) {
                var text = (card.textContent || '').toLowerCase();
                card.style.display = !query || text.indexOf(query) > -1 ? '' : 'none';
            });
        }

        function showAddModal() {
            document.getElementById('editAssetId').value = '';
            document.getElementById('assetModalTitle').textContent = '添加' + typeName;
            document.getElementById('assetName').value = '';
            document.getElementById('assetDesc').value = '';
            document.getElementById('assetOrder').value = '0';
            showResourcePreviewInEdit(null, '');
            setupParentSelect(false);
            showModal('assetModal');
            setTimeout(function() { document.getElementById('assetName').focus(); }, 100);
        }

        function showEditModal(btn) {
            var id = btn.getAttribute('data-id');
            var name = JSON.parse(btn.getAttribute('data-name'));
            var desc = JSON.parse(btn.getAttribute('data-desc') || '""');
            var order = parseInt(btn.getAttribute('data-order')) || 0;
            var card = btn.closest('.asset-detail-card');
            var imgSrc = card ? card.getAttribute('data-imgsrc') || '' : '';
            var parentId = card ? card.getAttribute('data-parentid') || '' : '';
            document.getElementById('editAssetId').value = id;
            document.getElementById('assetModalTitle').textContent = '编辑' + typeName;
            document.getElementById('assetName').value = name;
            document.getElementById('assetDesc').value = desc;
            document.getElementById('assetOrder').value = order;
            document.getElementById('assetParentId').value = parentId;
            showResourcePreviewInEdit('编辑资源', imgSrc);
            setupParentSelect(true);
            showModal('assetModal');
            setTimeout(function() { document.getElementById('assetName').focus(); }, 100);
        }

        function setupParentSelect(forEdit) {
            var isVoice = currentType === 2;
            var group = document.getElementById('parentSelectGroup');
            var sel = document.getElementById('assetParentId');

            if (!isVoice) {
                group.style.display = 'none';
                sel.required = false;
                return;
            }

            group.style.display = '';
            sel.required = true;
            sel.innerHTML = '<option value="">请选择父资产...</option>';

            // parent types: Actor (1) and Prop (5)
            var parentTypes = [1, 5];
            var parentTypeNames = { 1: '角色', 5: '道具' };
            var fetches = parentTypes.map(function(t) {
                return fetch('/Assets/ListByProject?projectId=' + projectId + '&type=' + t)
                    .then(function(r) { return r.json(); })
                    .then(function(res) {
                        var list = res.data || [];
                        if (list.length > 0) {
                            var optgroup = document.createElement('optgroup');
                            optgroup.label = parentTypeNames[t];
                            list.forEach(function(a) {
                                var opt = document.createElement('option');
                                opt.value = a.id;
                                opt.textContent = a.name;
                                optgroup.appendChild(opt);
                            });
                            sel.appendChild(optgroup);
                        }
                    });
            });

            Promise.all(fetches).then(function() {
                if (forEdit) {
                    // restore parent value after options load
                }
            });
        }

        function showResourcePreviewInEdit(title, imgSrc) {
            var group = document.getElementById('resourcePreviewGroup');
            var img = document.getElementById('resourcePreviewImg');
            var noImg = document.getElementById('resourceNoImage');
            var titleEl = document.getElementById('resourcePreviewTitle');
            if (imgSrc) {
                group.style.display = '';
                img.src = imgSrc;
                img.style.display = '';
                noImg.style.display = 'none';
                if (title) {
                    titleEl.textContent = title;
                    titleEl.style.display = '';
                } else {
                    titleEl.style.display = 'none';
                }
            } else {
                group.style.display = 'none';
            }
        }

        function saveAsset() {
            var id = document.getElementById('editAssetId').value;
            var name = document.getElementById('assetName').value.trim();
            var desc = document.getElementById('assetDesc').value.trim();
            var order = parseInt(document.getElementById('assetOrder').value) || 0;
            if (!name) { alert('请输入名称'); return; }

            var parentId = document.getElementById('assetParentId').value;
            var isVoice = currentType === 2;
            if (isVoice && !parentId) { alert('声音资产必须选择父节点（所属角色或道具）'); return; }

            if (id) {
                fetch('/Assets/Edit', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ id: id, name: name, description: desc, order: order, parentId: parentId })
                })
                .then(function(r) { return r.text().then(function(t) { try { return JSON.parse(t); } catch(e) { return {success:false,message:t}; } }); })
                .then(function(res) {
                    if (res.success) {
                        hideModal('assetModal');
                        window.location.reload();
                    } else {
                        alert('保存失败: ' + (res.message || ''));
                    }
                })
                .catch(function(err) { alert('请求失败: ' + err.message); });
            } else {
                fetch('/Assets/Create', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ projectId: projectId, assetType: currentType, name: name, description: desc, order: order, parentId: parentId || '' })
                })
                .then(function(r) { return r.text().then(function(t) { try { return JSON.parse(t); } catch(e) { return {success:false,message:t}; } }); })
                .then(function(res) {
                    if (res.success) {
                        hideModal('assetModal');
                        window.location.reload();
                    } else {
                        alert('保存失败: ' + (res.message || ''));
                    }
                })
                .catch(function(err) { alert('请求失败: ' + err.message); });
            }
        }

        function showReplaceModal(btn) {
            var id = btn.getAttribute('data-id');
            var name = JSON.parse(btn.getAttribute('data-name'));
            var isBgm = btn.getAttribute('data-isbgm') === 'true';
            document.getElementById('replaceAssetId').value = id;
            document.getElementById('replaceResourceTitle').textContent = isBgm ? '替换音频: ' + name : '替换图片: ' + name;
            var fileInput = document.getElementById('replaceFileInput');
            fileInput.accept = isBgm ? "audio/*" : "image/*";
            fileInput.value = '';
            document.getElementById('replacePreviewImg').style.display = 'none';
            document.getElementById('replacePreviewImg').src = '';
            showModal('replaceResourceModal');
            setTimeout(function() { fileInput.focus(); }, 100);
        }

        function uploadReplace() {
            var fileInput = document.getElementById('replaceFileInput');
            var file = fileInput && fileInput.files && fileInput.files[0];
            if (!file) { alert('请选择文件'); return; }

            var accept = fileInput.getAttribute('accept');
            var isBgm = accept === 'audio/*';
            var fd = new FormData();
            fd.append('assetid', document.getElementById('replaceAssetId').value);
            fd.append('projectid', projectId);
            fd.append('uploadFile', file);
            var url = isBgm ? '/Assets/ReplaceAudio' : '/Assets/ReplaceResource';
            fetch('/Assets/ReplaceResource', { method: 'POST', body: fd })
            .then(function(r) { return r.text().then(function(t) { try { return JSON.parse(t); } catch(e) { return {success:false,message:t}; } }); })
            .then(function(res) {
                if (res.success) {
                    hideModal('replaceResourceModal');
                    window.location.reload();
                } else {
                    alert('替换失败: ' + (res.message || ''));
                }
            })
            .catch(function(err) { alert('请求失败: ' + err.message); });
        }

        function deleteAssetFromId(id, name) {
            if (!confirm('确认删除「' + name + '」？')) return;
            fetch('/Assets/Delete', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id: id })
            })
            .then(function(r) { return r.text().then(function(t) { try { return JSON.parse(t); } catch(e) { return {success:false,message:t}; } }); })
            .then(function(res) {
                if (res.success) {
                    showToast('已删除', 'success');
                    window.location.reload();
                } else {
                    alert('删除失败: ' + (res.message || ''));
                }
            })
            .catch(function(err) { alert('删除请求失败: ' + err.message); });
        }

        function clearAllAssets() {
            if (!confirm('确认清除当前项目所有资产？此操作不可撤销！')) return;
            if (!confirm('再次确认：将删除当前项目的全部资产数据！')) return;
            fetch('/Assets/ClearAll', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ projectId: projectId })
            })
            .then(function(r) { return r.json(); })
            .then(function(res) {
                if (res.success) {
                    showToast(res.message, 'success');
                    window.location.reload();
                } else {
                    alert('清除失败: ' + (res.message || ''));
                }
            })
            .catch(function(err) { alert('请求失败: ' + err.message); });
        }

        function showReplaceModalFromClick(assetId, name, isBgm) {
            document.getElementById('replaceAssetId').value = assetId;
            document.getElementById('replaceResourceTitle').textContent = isBgm ? '替换音频: ' + name : '替换图片: ' + name;
            var fileInput = document.getElementById('replaceFileInput');
            fileInput.accept = isBgm ? "audio/*" : "image/*";
            fileInput.value = '';
            document.getElementById('replacePreviewImg').style.display = 'none';
            document.getElementById('replacePreviewImg').src = '';
            showModal('replaceResourceModal');
            setTimeout(function() { fileInput.focus(); }, 100);
        }

        function showEditModal(btn) {
            document.querySelectorAll('.action-edit').forEach(function(btn) {
                btn.addEventListener('click', function(e) {
                    e.preventDefault();
                    e.stopPropagation();
                    showEditModal(this);
                });
            });
            document.querySelectorAll('.action-ai').forEach(function(btn) {
                btn.addEventListener('click', function(e) {
                    e.preventDefault();
                    e.stopPropagation();
                    showAiGenerateModal(this);
                });
            });
            document.querySelectorAll('.action-delete').forEach(function(btn) {
                btn.addEventListener('click', function(e) {
                    e.preventDefault();
                    e.stopPropagation();
                    var id = btn.getAttribute('data-id');
                    var name = JSON.parse(btn.getAttribute('data-name'));
                    deleteAssetFromId(id, name);
                });
            });
        }

        function showAiGenerateModal(btn) {
            var id = btn.getAttribute('data-id');
            var type = btn.getAttribute('data-type');
            var name = JSON.parse(btn.getAttribute('data-name'));
            var isBgm = btn.getAttribute('data-isbgm') === 'true';

            document.getElementById('aiAssetId').value = id;
            document.getElementById('aiAssetType').value = type;
            document.getElementById('aiAssetName').value = name;

            var titles = { 'Actor': 'AI 生成角色图', 'Scene': 'AI 生成场景图', 'Bgm': 'AI 生成 BGM', 'Prop': 'AI 生成道具图', 'VoiceVoice': 'AI 生成角色声音' };
            document.getElementById('aiGenerateTitle').textContent = (titles[type] || 'AI 生成') + ': ' + name;

            var promptEl = document.getElementById('aiGenPrompt');
            promptEl.value = '';
            promptEl.placeholder = isBgm ? '描述你想要的 BGM 风格、情绪、节奏...' : assetType === 'VoiceVoice' ? '描述角色的声音特征、语气、语速、情感...' : '输入描述词，如：穿着红色长裙的女性角色，正面视角，白背景...';

            var extraFields = document.getElementById('aiGenExtraFields');
            extraFields.innerHTML = '';

            var resultEl = document.getElementById('aiGenResult');
            resultEl.style.display = 'none';
            resultEl.innerHTML = '';

            var genBtn = document.getElementById('aiGenBtn');
            genBtn.disabled = false;
            genBtn.textContent = '开始生成';

            showModal('aiGenerateModal');
        }

        function doAiGenerate() {
            var assetId = document.getElementById('aiAssetId').value;
            var assetType = document.getElementById('aiAssetType').value;
            var prompt = document.getElementById('aiGenPrompt').value.trim();

            if (!prompt) { alert('请输入提示词'); return; }

            var genBtn = document.getElementById('aiGenBtn');
            var resultEl = document.getElementById('aiGenResult');
            var extraFields = document.getElementById('aiGenExtraFields');

            genBtn.disabled = true;
            genBtn.textContent = '生成中...';
            resultEl.style.display = 'none';
            extraFields.innerHTML = '<div style="padding:12px;background:#f0f0f0;border-radius:8px;margin-top:12px;text-align:center;color:#666;">正在提交任务，请稍候...</div>';

            var payload = { prompt: prompt };
            var endpoint = '';
            var workflowType = '';

            if (assetType === 'Bgm') {
                endpoint = '/api/comfyui/stable-bgm/generate';
                workflowType = 'stable-bgm-generate';
            } else if (assetType === 'VoiceVoice') {
                endpoint = '/api/comfyui/ace-music/compose';
                workflowType = 'ace-music-compose';
            } else {
                endpoint = '/api/comfyui/zimage/text-to-image';
                workflowType = 'zimage-text-to-image';
            }

            fetch(endpoint, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            })
            .then(function(r) { return r.json(); })
            .then(function(res) {
                var promptId = res && res.promptId;

                if (!promptId) {
                    alert('提交失败: ' + (res.message || '未知错误'));
                    genBtn.disabled = false;
                    genBtn.textContent = '开始生成';
                    extraFields.innerHTML = '';
                    return;
                }

                extraFields.innerHTML = '<div style="padding:12px;background:#e8f4fd;border-radius:8px;margin-top:12px;"><div style="color:#004085;font-weight:bold;margin-bottom:8px;">任务已提交，正在后台生成中...</div><div style="color:#666;font-size:13px;">promptId: ' + promptId + '</div></div>';

                pollAiResult(promptId, workflowType, assetId, assetType);
            })
            .catch(function(err) {
                alert('请求失败: ' + err.message);
                genBtn.disabled = false;
                genBtn.textContent = '开始生成';
                extraFields.innerHTML = '';
            });
        }

        function pollAiResult(promptId, workflowType, assetId, assetType) {
            var resultEl = document.getElementById('aiGenResult');
            var extraFields = document.getElementById('aiGenExtraFields');
            var genBtn = document.getElementById('aiGenBtn');
            var pollCount = 0;
            var maxPolls = 120;
            var pollInterval = 5000;

            var pollTimer = setInterval(function() {
                pollCount++;

                if (pollCount >= maxPolls) {
                    clearInterval(pollTimer);
                    extraFields.innerHTML = '<div style="padding:12px;background:#fff3cd;border-radius:8px;margin-top:12px;"><div style="color:#856404;font-weight:bold;">生成超时</div><div style="color:#666;font-size:13px;margin-top:4px;">promptId: ' + promptId + '</div><button class="btn btn-sm btn-primary" style="margin-top:8px;" onclick=\'fetchAiResult("' + promptId + '","' + workflowType + '",' + assetId + ',"' + assetType + '")\'>获取结果</button><button class="btn btn-sm btn-ghost" style="margin-top:8px;margin-left:4px;" onclick="hideModal(\'aiGenerateModal\')">关闭</button></div>';
                    genBtn.disabled = false;
                    genBtn.textContent = '重新生成';
                    return;
                }

                var resultType = (assetType === 'Bgm' || assetType === 'VoiceVoice') ? 'audio' : 'image';
                var url = '/api/v1/comfyui/result/' + promptId + '/' + resultType + '?workflowType=' + encodeURIComponent(workflowType);
                fetch(url)
                .then(function(r) { return r.json(); })
                .then(function(res) {
                    if (res.success && res.data) {
                        clearInterval(pollTimer);
                        var urls = [];
                        var data = res.data;

                        if (data.imageUrls && Array.isArray(data.imageUrls)) {
                            urls = data.imageUrls;
                        } else if (data.audioUrls && Array.isArray(data.audioUrls)) {
                            urls = data.audioUrls;
                        } else if (data.videoUrls && Array.isArray(data.videoUrls)) {
                            urls = data.videoUrls;
                        }

                        if (urls.length > 0) {
                            handleAiResultSuccess(assetId, assetType, urls[0]);
                        } else {
                            extraFields.innerHTML = '<div style="padding:12px;background:#f0f0f0;border-radius:8px;margin-top:12px;color:#666;">任务已完成但未找到结果</div>';
                            genBtn.disabled = false;
                            genBtn.textContent = '重新生成';
                        }
                    } else if (!res.pending) {
                        clearInterval(pollTimer);
                        extraFields.innerHTML = '<div style="padding:12px;background:#f0f0f0;border-radius:8px;margin-top:12px;color:#666;">' + (res.message || '任务执行失败') + '</div>';
                        genBtn.disabled = false;
                        genBtn.textContent = '重新生成';
                    }
                })
                .catch(function() {
                    if (pollCount >= maxPolls) return;
                });
            }, pollInterval);
        }

        function fetchAiResult(promptId, wfType, assetId, assetType) {
            pollAiResult(promptId, wfType || 'zimage-text-to-image', assetId, assetType);
        }

        function handleAiResultSuccess(assetId, assetType, fileUrl) {
            var resultEl = document.getElementById('aiGenResult');
            var extraFields = document.getElementById('aiGenExtraFields');
            var genBtn = document.getElementById('aiGenBtn');

            resultEl.style.display = 'none';

            if (assetType === 'Bgm' || assetType === 'VoiceVoice') {
                extraFields.innerHTML = '<div style="padding:12px;background:#d4edda;border-radius:8px;margin-top:12px;"><div style="color:#155724;font-weight:bold;">✅ ' + (assetType === 'Bgm' ? 'BGM' : '角色声音') + ' 生成成功</div><div style="margin-top:8px;"><a href="' + fileUrl + '" target="_blank" style="color:#004085;">播放音频</a></div></div>';

                fetch('/Assets/ReplaceAudio', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ assetId: assetId, fileUrl: fileUrl })
                })
                .then(function(r) { return r.json(); })
                .then(function(res) {
                    if (res.success) {
                        showToast(assetType === 'VoiceVoice' ? '角色声音已更新' : 'BGM 已更新', 'success');
                        setTimeout(function() { window.location.reload(); }, 1000);
                    } else {
                        extraFields.innerHTML += '<div style="padding:8px;background:#fff3cd;border-radius:8px;margin-top:8px;color:#856404;">⚠️ 生成成功但更新资源失败</div>';
                        genBtn.disabled = false;
                        genBtn.textContent = '重新生成';
                    }
                })
                .catch(function() {
                    extraFields.innerHTML += '<div style="padding:8px;background:#f8d7da;border-radius:8px;margin-top:8px;color:#721c24;">⚠️ 更新资源请求失败</div>';
                    genBtn.disabled = false;
                    genBtn.textContent = '重新生成';
                });
            } else {
                extraFields.innerHTML += '<div style="padding:12px;background:#d4edda;border-radius:8px;margin-top:12px;"><div style="color:#155724;font-weight:bold;">✅ 图片生成成功</div><img src="' + fileUrl + '" style="max-width:100%;margin-top:8px;border-radius:8px;" /></div>';

                fetch('/Assets/ReplaceResource', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ assetId: assetId, fileUrl: fileUrl })
                })
                .then(function(r) { return r.json(); })
                .then(function(res) {
                    if (res.success) {
                        showToast('资源已更新', 'success');
                        setTimeout(function() { window.location.reload(); }, 1000);
                    } else {
                        extraFields.innerHTML += '<div style="padding:8px;background:#fff3cd;border-radius:8px;margin-top:8px;color:#856404;">⚠️ 生成成功但更新资源失败</div>';
                        genBtn.disabled = false;
                        genBtn.textContent = '重新生成';
                    }
                })
                .catch(function() {
                    extraFields.innerHTML += '<div style="padding:8px;background:#f8d7da;border-radius:8px;margin-top:8px;color:#721c24;">⚠️ 更新资源请求失败</div>';
                    genBtn.disabled = false;
                    genBtn.textContent = '重新生成';
                });
            }
        }

        function showImagePreview(src, title) {
            if (!src) { return; }
            document.getElementById('previewImageTitle').textContent = title;
            document.getElementById('previewImage').src = src;
            showModal('imagePreviewModal');
        }

        function playBgm(src, title) {
            if (!src) { return; }
            var audioId = src.split('/').pop();
            var audio = document.getElementById('audio-' + audioId.replace(/\.[^.]+$/, ''));
            if (!audio) { return; }
            var wasPlaying = audio.paused;
            document.querySelectorAll('audio').forEach(function(a) { a.pause(); });
            if (wasPlaying) {
                audio.play();
            } else {
                audio.play();
            }
            showImagePreview(src, title);
        }

        document.addEventListener('DOMContentLoaded', function() {
            setupButtonListeners();
            checkPendingExtractAssets();
        });

        function checkPendingExtractAssets() {
            var key = 'extractAssetResult_' + projectId;
            var raw = sessionStorage.getItem(key);
            if (!raw) return;

            sessionStorage.removeItem(key);
            var parsed;
            try { parsed = JSON.parse(raw); } catch(e) { return; }

            var assetsArray = Array.isArray(parsed) ? parsed : (parsed.assets && Array.isArray(parsed.assets) ? parsed.assets : null);
            if (!assetsArray || assetsArray.length === 0) return;

            showExtractMergeModal(assetsArray);
        }

        var _mergeAssetList = [];

        function showExtractMergeModal(aiAssets) {
            _mergeAssetList = aiAssets;
            var typeIcons = { 'Actor':'\uD83D\uDCC8', 'Scene':'\uD83C\uDFD0', 'Bgm':'\uD83C\uDFA5', 'Prop':'\uD83D\uDD25', 'VoiceVoice':'\uD83C\uDFA4' };
            var names = { 'Actor':'角色', 'Scene':'场景', 'Bgm':'BGM', 'Prop':'道具', 'VoiceVoice':'声音' };

            var h = '<div class="modal-header"><h3>\uD83C\uDFAF AI 提取资产 - 确认合并</h3><button class="modal-close" onclick="hideModal(\'extractMergeModal\')">&times;</button></div>';
            h += '<div class="modal-body">';
            h += '<p style="color:var(--text2);font-size:13px;margin-bottom:16px;">AI 从章节中提取了以下资产，请勾选需要保存的项：</p>';
            h += '<div id="mergeAssetList" style="max-height:400px;overflow-y:auto;">';

            aiAssets.forEach(function(a, i) {
                var icon = typeIcons[a.assetType] || '\uD83D\uDCC4';
                var typeLabel = names[a.assetType] || a.assetType || '';
                h += '<label style="display:flex;align-items:flex-start;gap:10px;padding:10px 12px;border:1px solid var(--border);border-radius:6px;margin-bottom:6px;cursor:pointer;transition:.1s;" onmouseover="this.style.background=\'var(--bg)\'" onmouseout="this.style.background=\'\'">'
                    + '<input type="checkbox" class="merge-chk" value="' + i + '" checked style="margin-top:3px;accent-color:var(--primary);">'
                    + '<div style="flex:1;min-width:0;">'
                    + '<div style="display:flex;align-items:center;gap:6px;">'
                    + '<span>' + icon + '</span>'
                    + '<strong style="font-size:14px;">' + escapeHtml(a.name || '') + '</strong>'
                    + '<span class="asset-badge asset-badge-' + (a.assetType || '').toLowerCase() + '" style="font-size:10px;">' + typeLabel + '</span>'
                    + '</div>'
                    + '<div style="font-size:12px;color:var(--text3);margin-top:4px;line-height:1.5;">' + escapeHtml(a.description || '暂无描述') + '</div>'
                    + '</div>'
                    + '</label>';
            });

            h += '</div></div>';
            h += '<div class="modal-footer">'
                + '<button class="btn btn-ghost" onclick="hideModal(\'extractMergeModal\')">取消</button>'
                + '<button class="btn btn-primary" id="mergeSaveBtn" onclick="saveMergeAssets()">保存勾选 (' + aiAssets.length + ')</button>'
                + '</div>';

            var overlay = document.getElementById('extractMergeModal');
            if (!overlay) {
                overlay = document.createElement('div');
                overlay.className = 'modal-overlay';
                overlay.id = 'extractMergeModal';
                document.body.appendChild(overlay);
            }
            overlay.innerHTML = '<div class="modal" style="width:600px;max-height:90vh;">' + h + '</div>';
            showModal('extractMergeModal');

            document.querySelectorAll('#mergeAssetList .merge-chk').forEach(function(c) {
                c.addEventListener('change', function() {
                    var total = _mergeAssetList.length;
                    var sel = document.querySelectorAll('#mergeAssetList .merge-chk:checked').length;
                    document.getElementById('mergeSaveBtn').textContent = '保存勾选 (' + sel + ')';
                });
            });
        }

        function saveMergeAssets() {
            var chks = document.querySelectorAll('#mergeAssetList .merge-chk:checked');
            if (chks.length === 0) { alert('请至少勾选一个资产'); return; }

            var selected = [];
            chks.forEach(function(c) {
                var idx = parseInt(c.value);
                selected.push(_mergeAssetList[idx]);
            });

            var btn = document.getElementById('mergeSaveBtn');
            btn.disabled = true;
            btn.textContent = '保存中...';

            fetch('/Assets/BulkCreate', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ projectId: projectId, assets: selected })
            })
            .then(function(r) { return r.json(); })
            .then(function(res) {
                if (res.success) {
                    showToast(res.message, 'success');
                    hideModal('extractMergeModal');
                    setTimeout(function() { window.location.reload(); }, 800);
                } else {
                    alert('保存失败：' + (res.message || '未知错误'));
                    btn.disabled = false;
                    btn.textContent = '保存勾选 (' + selected.length + ')';
                }
            })
            .catch(function(err) {
                alert('网络错误：' + err.message);
                btn.disabled = false;
                btn.textContent = '保存勾选 (' + selected.length + ')';
            });
        }

        // ---- 批量导入 ----
        var _assetImportNewAssets = null;

        function showAssetImportModal() {
            document.getElementById('assetImportJson').value = '';
            showModal('assetImportModal');
        }

        function doAssetImport() {
            var jsonStr = document.getElementById('assetImportJson').value.trim();
            if (!jsonStr) { alert('请粘贴 JSON 资产数据'); return; }

            var parsed;
            try { parsed = JSON.parse(jsonStr); } catch(e) {
                alert('JSON 格式错误：' + e.message);
                return;
            }
            var assets = Array.isArray(parsed) ? parsed : (parsed.assets || []);
            if (assets.length === 0) { alert('未找到资产数据'); return; }

            hideModal('assetImportModal');
            showAssetImportMergeView(assets);
        }

        function showAssetImportMergeView(importAssets) {
            _assetImportNewAssets = importAssets;
            var typeNames = { 'Actor':'角色', 'Scene':'场景', 'Bgm':'BGM', 'Prop':'道具', 'VoiceVoice':'声音' };

            fetch('/Assets/ListByProject?projectId=' + projectId)
                .then(function(r){ return r.json(); })
                .then(function(res){
                    var existingNames = new Set((res.data || []).map(function(a){ return a.name.toLowerCase(); }));
                    renderAssetImportMergeList(importAssets, existingNames);
                })
                .catch(function(){
                    renderAssetImportMergeList(importAssets, new Set());
                });
        }

        function renderAssetImportMergeList(assets, existingNames) {
            var typeNames = { 'Actor':'角色', 'Scene':'场景', 'Bgm':'BGM', 'Prop':'道具', 'VoiceVoice':'声音' };
            var typeIcons = { 'Actor':'\uD83D\uDC64', 'Scene':'\uD83C\uDFD0\uFE0F', 'Bgm':'\uD83C\uDFB5', 'Prop':'\uD83D\uDD25', 'VoiceVoice':'\uD83C\uDFA4' };
            var html = '';
            assets.forEach(function(a, i){
                var icon = typeIcons[a.assetType] || '\uD83D\uDCC4';
                var typeLabel = typeNames[a.assetType] || a.assetType || '';
                var exists = existingNames.has((a.name || '').toLowerCase());
                var indent = a.belong ? 'margin-left:20px;' : '';
                var existsTag = exists ? '<span style="color:var(--danger);font-size:10px;font-weight:600;">已存在</span>' : '<span style="color:var(--ok);font-size:10px;font-weight:600;">新资产</span>';
                html += '<div style="display:flex;align-items:flex-start;gap:8px;padding:8px 10px;border-bottom:1px solid var(--border);' + indent + '">'
                    + '<input type="checkbox" class="asset-import-chk" value="' + i + '" ' + (exists ? '' : 'checked') + ' data-exists="' + exists + '" style="margin-top:3px;accent-color:var(--primary);">'
                    + '<div style="flex:1;min-width:0;">'
                    + '<div style="display:flex;align-items:center;gap:4px;font-size:13px;">'
                    + '<span>' + icon + '</span>'
                    + '<strong>' + escapeHtml(a.name || '') + '</strong>'
                    + '<span style="color:var(--text3);font-size:10px;">[' + typeLabel + ']</span>'
                    + (a.belong ? '<span style="color:var(--sec);font-size:10px;">→ ' + escapeHtml(a.belong) + '</span>' : '')
                    + '</div>'
                    + '<div style="font-size:12px;color:var(--text3);margin-top:2px;line-height:1.5;">' + escapeHtml((a.description || '') || '暂无描述') + '</div>'
                    + '</div>'
                    + '<div style="white-space:nowrap;font-size:11px;">' + existsTag + '</div>'
                    + '</div>';
            });
            document.getElementById('assetImportMergeList').innerHTML = html;
            var total = assets.length;
            var sel = document.querySelectorAll('#assetImportMergeList .asset-import-chk:checked').length;
            document.getElementById('assetImportMergeSaveBtn').textContent = '保存勾选 (' + sel + '/' + total + ')';
            document.querySelectorAll('#assetImportMergeList .asset-import-chk').forEach(function(c){
                c.addEventListener('change', function(){
                    var s = document.querySelectorAll('#assetImportMergeList .asset-import-chk:checked').length;
                    document.getElementById('assetImportMergeSaveBtn').textContent = '保存勾选 (' + s + '/' + total + ')';
                });
            });
            showModal('assetImportMergeModal');
        }

        function copyAssetImportJson() {
            var json = JSON.stringify(_assetImportNewAssets, null, 2);
            navigator.clipboard.writeText(json).then(function() {
                showToast('已复制 JSON 到剪贴板', 'success');
            }).catch(function() {
                var ta = document.createElement('textarea');
                ta.value = json;
                document.body.appendChild(ta);
                ta.select();
                document.execCommand('copy');
                document.body.removeChild(ta);
                showToast('已复制 JSON 到剪贴板', 'success');
            });
        }

        function saveAssetImportMerge() {
            var chks = document.querySelectorAll('#assetImportMergeList .asset-import-chk:checked');
            if (chks.length === 0) { alert('请至少勾选一个资产'); return; }

            var selected = [];
            chks.forEach(function(c){
                var idx = parseInt(c.value);
                var item = _assetImportNewAssets[idx];
                var exists = c.getAttribute('data-exists') === 'true';
                selected.push({
                    name: item.name,
                    assetType: item.assetType,
                    description: item.description || '',
                    parentName: item.belong || '',
                    override: exists
                });
            });

            var btn = document.getElementById('assetImportMergeSaveBtn');
            btn.disabled = true;
            btn.textContent = '保存中...';

            fetch('/Assets/BulkCreate', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ projectId: projectId, assets: selected })
            })
            .then(function(r){ return r.json(); })
            .then(function(res){
                btn.disabled = false;
                btn.textContent = '保存勾选';
                if (res.success) {
                    showToast(res.message, 'success');
                    hideModal('assetImportMergeModal');
                    setTimeout(function() { window.location.reload(); }, 800);
                } else {
                    alert('保存失败：' + (res.message || '未知错误'));
                }
            })
            .catch(function(err){
                btn.disabled = false;
                btn.textContent = '保存勾选';
                alert('网络错误：' + err.message);
            });
        }
    </script>
}
